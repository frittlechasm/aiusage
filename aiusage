#!/usr/bin/env bash
set -euo pipefail

# ── config ──────────────────────────────────────────────
BAR_WIDTH=20
FILL="█"
EMPTY="░"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
DIM="\033[2m"
BOLD="\033[1m"
RESET="\033[0m"

# ── helpers ─────────────────────────────────────────────

draw_bar() {
  local label="$1" percent="$2"
  percent="${percent%.*}"
  [[ -z "$percent" ]] && percent=0
  ((percent < 0)) && percent=0
  ((percent > 100)) && percent=100

  local filled=$((percent * BAR_WIDTH / 100))
  local empty=$((BAR_WIDTH - filled))

  # pick color
  local color="$GREEN"
  ((percent >= 60)) && color="$YELLOW"
  ((percent >= 85)) && color="$RED"

  local bar="${color}"
  for ((i = 0; i < filled; i++)); do bar+="$FILL"; done
  bar+="${DIM}"
  for ((i = 0; i < empty; i++)); do bar+="$EMPTY"; done
  bar+="${RESET}"

  printf "  %-8s %b %3d%%\n" "$label" "$bar" "$percent"
}

draw_unavailable() {
  local label="$1"
  local bar="${DIM}"
  for ((i = 0; i < BAR_WIDTH; i++)); do bar+="$EMPTY"; done
  bar+="${RESET}"
  printf "  %-8s %b  --%%\n" "$label" "$bar"
}

http_json() {
  curl -sf --max-time 10 "$@" 2>/dev/null || echo ""
}

normalize_epoch() {
  local raw="${1:-}"
  [[ -z "$raw" || "$raw" == "null" ]] && return 0

  if [[ "$raw" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    local int="${raw%%.*}"
    # Convert milliseconds to seconds when timestamps are too large.
    ((int > 100000000000)) && int=$((int / 1000))
    echo "$int"
    return 0
  fi

  # Claude often returns ISO timestamps with fractional seconds and/or offsets.
  # Normalize those variants and parse with local `date`.
  local cleaned
  cleaned=$(printf "%s" "$raw" | sed -E 's/([0-9])\.[0-9]+/\1/')
  if [[ "$cleaned" == *Z ]]; then
    cleaned="${cleaned%Z}+0000"
  fi
  cleaned=$(printf "%s" "$cleaned" | sed -E 's/([+-][0-9]{2}):([0-9]{2})$/\1\2/')

  if date -j -f "%Y-%m-%dT%H:%M:%S%z" "$cleaned" "+%s" >/dev/null 2>&1; then
    date -j -f "%Y-%m-%dT%H:%M:%S%z" "$cleaned" "+%s"
    return 0
  fi

  if date -j -f "%Y-%m-%dT%H:%M:%S" "$cleaned" "+%s" >/dev/null 2>&1; then
    date -j -f "%Y-%m-%dT%H:%M:%S" "$cleaned" "+%s"
    return 0
  fi

  # Linux/GNU fallback.
  date -d "$raw" "+%s" 2>/dev/null || true
}

format_epoch_local() {
  local epoch="${1:-}" mode="${2:-datetime}"
  [[ -z "$epoch" ]] && return 0

  local format="+%b %d %I:%M%p" value=""
  [[ "$mode" == "time" ]] && format="+%I:%M%p"

  if date -r "$epoch" "$format" >/dev/null 2>&1; then
    value=$(date -r "$epoch" "$format")
  else
    value=$(date -d "@$epoch" "$format" 2>/dev/null || true)
  fi

  if [[ "$mode" == "time" ]]; then
    value=$(printf "%s" "$value" | sed -E 's/^0//; s/AM$/am/; s/PM$/pm/')
  fi

  printf "%s" "$value"
}

format_remaining() {
  local seconds="${1:-}"
  [[ -z "$seconds" ]] && echo "unknown" && return 0

  if ((seconds <= 0)); then
    echo "now"
    return 0
  fi

  local days=$((seconds / 86400))
  local hours=$(((seconds % 86400) / 3600))
  local minutes=$(((seconds % 3600) / 60))

  if ((days > 0)); then
    printf "%dd %dh" "$days" "$hours"
  elif ((hours > 0)); then
    printf "%dh %dm" "$hours" "$minutes"
  else
    printf "%dm" "$minutes"
  fi
}

draw_reset() {
  local epoch="${1:-}" mode="${2:-datetime}"
  local reset_text="--"

  if [[ -n "$epoch" ]]; then
    local formatted now rel
    formatted=$(format_epoch_local "$epoch" "$mode")
    if [[ -n "$formatted" ]]; then
      now=$(date +%s)
      rel=$(format_remaining $((epoch - now)))
      reset_text="$formatted ($rel)"
    fi
  fi

  printf "  %-8s ${DIM}reset: %s${RESET}\n" "" "$reset_text"
}

SPINNER_FRAMES=('|' '/' '-' '\')

spinner_frame() {
  local frame="${1:-0}"
  local idx=$((frame % ${#SPINNER_FRAMES[@]}))
  printf "%s" "${SPINNER_FRAMES[$idx]}"
}

clear_render_block() {
  local lines="${1:-0}" i
  ((lines <= 0)) && return 0

  printf "\033[%dF" "$lines"
  for ((i = 0; i < lines; i++)); do
    printf "\033[2K"
    if ((i < lines - 1)); then
      printf "\033[1E"
    fi
  done
  if ((lines > 1)); then
    printf "\033[%dF" "$((lines - 1))"
  fi
}

SECTION_LINES=0
render_provider_section() {
  local label="$1" tmp_file="$2" done="$3" frame="$4"
  local lines=0

  if ((done)); then
    printf "${BOLD}%s${RESET}\n" "$label"
    lines=1
    while IFS= read -r line || [[ -n "$line" ]]; do
      printf "%s\n" "$line"
      ((lines++))
    done < "$tmp_file"
  else
    local spin
    spin=$(spinner_frame "$frame")
    printf "${BOLD}%s${RESET} ${DIM}%s${RESET}\n" "$label" "$spin"
    lines=1
  fi

  SECTION_LINES="$lines"
}

RENDERED_LINES=0
render_fetch_state() {
  local frame="$1"
  local label1="$2" tmp1="$3" done1="$4"
  local label2="$5" tmp2="$6" done2="$7" has_second="$8"
  local lines=0

  render_provider_section "$label1" "$tmp1" "$done1" "$frame"
  lines=$((lines + SECTION_LINES))

  if ((has_second)); then
    printf "\n"
    ((lines++))
    render_provider_section "$label2" "$tmp2" "$done2" "$frame"
    lines=$((lines + SECTION_LINES))
  fi

  RENDERED_LINES="$lines"
}

wait_and_render_fetches() {
  local label1="$1" pid1="$2" tmp1="$3"
  local label2="${4:-}" pid2="${5:-}" tmp2="${6:-}"
  local has_second=0 frame=0 prev_lines=0
  local running1 running2 done1 done2

  [[ -n "$pid2" ]] && has_second=1

  while true; do
    running1=0
    running2=0
    done1=0
    done2=0

    kill -0 "$pid1" 2>/dev/null && running1=1 || done1=1
    if ((has_second)); then
      kill -0 "$pid2" 2>/dev/null && running2=1 || done2=1
    fi

    if [[ -t 1 ]]; then
      clear_render_block "$prev_lines"
      render_fetch_state "$frame" "$label1" "$tmp1" "$done1" "$label2" "$tmp2" "$done2" "$has_second"
      prev_lines="$RENDERED_LINES"
    fi

    if ((done1)) && ((!has_second || done2)); then
      break
    fi

    sleep 0.08
    ((frame++))
  done

  wait "$pid1" || true
  ((has_second)) && wait "$pid2" || true

  if [[ ! -t 1 ]]; then
    render_fetch_state "$frame" "$label1" "$tmp1" 1 "$label2" "$tmp2" "$has_second" "$has_second"
  fi
}

run_provider_with_loading() {
  local label="$1" fetch_fn="$2"
  local tmp
  tmp=$(mktemp)

  "$fetch_fn" >"$tmp" &
  local pid=$!

  wait_and_render_fetches "$label" "$pid" "$tmp"
  rm -f "$tmp"
}

run_all_parallel() {
  local claude_tmp codex_tmp
  claude_tmp=$(mktemp)
  codex_tmp=$(mktemp)

  fetch_claude >"$claude_tmp" &
  local claude_pid=$!

  fetch_codex >"$codex_tmp" &
  local codex_pid=$!

  wait_and_render_fetches "Claude" "$claude_pid" "$claude_tmp" "Codex" "$codex_pid" "$codex_tmp"
  rm -f "$claude_tmp" "$codex_tmp"
}

# ── claude ──────────────────────────────────────────────

fetch_claude() {
  local creds_file="$HOME/.claude/.credentials.json"
  local token=""

  if [[ -f "$creds_file" ]]; then
    token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds_file" 2>/dev/null)
  fi

  if [[ -z "$token" ]]; then
    # try macOS keychain
    token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null || true)
  fi

  if [[ -z "$token" ]]; then
    draw_unavailable "5h"
    draw_reset "" "time"
    draw_unavailable "Weekly"
    draw_reset ""
    return
  fi

  local resp
  resp=$(http_json \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    -H "Accept: application/json" \
    "https://api.anthropic.com/api/oauth/usage")

  if [[ -z "$resp" ]]; then
    draw_unavailable "5h"
    draw_reset "" "time"
    draw_unavailable "Weekly"
    draw_reset ""
    return
  fi

  local five_hour seven_day five_hour_reset seven_day_reset
  five_hour=$(echo "$resp" | jq -r '.five_hour.utilization // empty' 2>/dev/null)
  seven_day=$(echo "$resp" | jq -r '.seven_day.utilization // empty' 2>/dev/null)
  five_hour_reset=$(echo "$resp" | jq -r '.five_hour.reset_at // .five_hour.resets_at // .five_hour.resetAt // .five_hour.resetsAt // .five_hour.window_end // .five_hour.window_end_at // .five_hour.windowEnd // .five_hour.windowEndAt // empty' 2>/dev/null)
  seven_day_reset=$(echo "$resp" | jq -r '.seven_day.reset_at // .seven_day.resets_at // .seven_day.resetAt // .seven_day.resetsAt // .seven_day.window_end // .seven_day.window_end_at // .seven_day.windowEnd // .seven_day.windowEndAt // empty' 2>/dev/null)

  local five_hour_reset_epoch seven_day_reset_epoch
  five_hour_reset_epoch=$(normalize_epoch "$five_hour_reset")
  seven_day_reset_epoch=$(normalize_epoch "$seven_day_reset")

  if [[ -n "$five_hour" ]]; then
    draw_bar "5h" "${five_hour%.*}"
  else
    draw_unavailable "5h"
  fi
  draw_reset "$five_hour_reset_epoch" "time"

  if [[ -n "$seven_day" ]]; then
    draw_bar "Weekly" "${seven_day%.*}"
  else
    draw_unavailable "Weekly"
  fi
  draw_reset "$seven_day_reset_epoch"
}

# ── codex ───────────────────────────────────────────────

fetch_codex() {
  local creds_file="${CODEX_HOME:-$HOME/.codex}/auth.json"
  local token="" account_id=""

  if [[ -f "$creds_file" ]]; then
    token=$(jq -r '.tokens.access_token // empty' "$creds_file" 2>/dev/null)
    account_id=$(jq -r '.tokens.account_id // empty' "$creds_file" 2>/dev/null)
  fi

  if [[ -z "$token" ]]; then
    draw_unavailable "5h"
    draw_reset "" "time"
    draw_unavailable "Weekly"
    draw_reset ""
    return
  fi

  local headers=(-H "Authorization: Bearer $token" -H "Accept: application/json")
  [[ -n "$account_id" ]] && headers+=(-H "ChatGPT-Account-Id: $account_id")

  local resp
  resp=$(http_json "${headers[@]}" "https://chatgpt.com/backend-api/wham/usage")

  if [[ -z "$resp" ]]; then
    draw_unavailable "5h"
    draw_reset "" "time"
    draw_unavailable "Weekly"
    draw_reset ""
    return
  fi

  local primary secondary primary_reset secondary_reset
  primary=$(echo "$resp" | jq -r '.rate_limit.primary_window.used_percent // empty' 2>/dev/null)
  secondary=$(echo "$resp" | jq -r '.rate_limit.secondary_window.used_percent // empty' 2>/dev/null)
  primary_reset=$(echo "$resp" | jq -r '.rate_limit.primary_window.reset_at // .rate_limit.primary_window.resets_at // .rate_limit.primary_window.resetAt // .rate_limit.primary_window.resetsAt // .rate_limit.primary_window.window_end // .rate_limit.primary_window.window_end_at // .rate_limit.primary_window.windowEnd // .rate_limit.primary_window.windowEndAt // empty' 2>/dev/null)
  secondary_reset=$(echo "$resp" | jq -r '.rate_limit.secondary_window.reset_at // .rate_limit.secondary_window.resets_at // .rate_limit.secondary_window.resetAt // .rate_limit.secondary_window.resetsAt // .rate_limit.secondary_window.window_end // .rate_limit.secondary_window.window_end_at // .rate_limit.secondary_window.windowEnd // .rate_limit.secondary_window.windowEndAt // empty' 2>/dev/null)

  local primary_reset_epoch secondary_reset_epoch
  primary_reset_epoch=$(normalize_epoch "$primary_reset")
  secondary_reset_epoch=$(normalize_epoch "$secondary_reset")

  if [[ -n "$primary" ]]; then
    draw_bar "5h" "$primary"
  else
    draw_unavailable "5h"
  fi
  draw_reset "$primary_reset_epoch" "time"

  if [[ -n "$secondary" ]]; then
    draw_bar "Weekly" "$secondary"
  else
    draw_unavailable "Weekly"
  fi
  draw_reset "$secondary_reset_epoch"
}

# ── main ────────────────────────────────────────────────

usage() {
  cat <<'EOF'
Usage: aiusage [provider]

Providers:
  claude   Show only Claude usage
  codex    Show only Codex usage

Pass No provider prints both.
EOF
}

provider="${1:-all}"

case "$provider" in
all)
  run_all_parallel
  ;;
claude)
  run_provider_with_loading "Claude" fetch_claude
  ;;
codex)
  run_provider_with_loading "Codex" fetch_codex
  ;;
-h | --help | help)
  usage
  exit 0
  ;;
*)
  printf "Unknown provider: %s\n\n" "$provider" >&2
  usage >&2
  exit 1
  ;;
esac

printf "\n"
