# Fast check: is any supported browser with sqlite3 present?
_cursor_has_browser() {
  command -v sqlite3 >/dev/null 2>&1 || return 1
  if [[ "$OSTYPE" == darwin* ]]; then
    [[ -d "$HOME/Library/Application Support/Firefox/Profiles" ]] ||
      [[ -d "$HOME/Library/Application Support/Google/Chrome" ]] ||
      [[ -d "$HOME/Library/Application Support/Chromium" ]] ||
      [[ -d "$HOME/Library/Application Support/Arc" ]] ||
      [[ -d "$HOME/Library/Application Support/BraveSoftware" ]] ||
      [[ -d "$HOME/Library/Application Support/Microsoft Edge" ]] ||
      [[ -d "$HOME/Library/Application Support/net.imput.helium" ]]
  else
    [[ -d "$HOME/.mozilla/firefox" ]] ||
      [[ -d "$HOME/.config/google-chrome" ]] ||
      [[ -d "$HOME/.config/chromium" ]] ||
      [[ -d "$HOME/.config/brave-browser" ]] ||
      [[ -d "$HOME/.config/net.imput.helium" ]]
  fi
}

# Extract WorkosCursorSessionToken from Firefox cookies.sqlite (unencrypted)
_cursor_cookie_firefox() {
  command -v sqlite3 >/dev/null 2>&1 || return 1
  local profiles_dir
  if [[ "$OSTYPE" == darwin* ]]; then
    profiles_dir="$HOME/Library/Application Support/Firefox/Profiles"
  else
    profiles_dir="$HOME/.mozilla/firefox"
  fi
  [[ -d "$profiles_dir" ]] || return 1

  local profile db tmp val
  for profile in "$profiles_dir"/*/; do
    db="$profile/cookies.sqlite"
    [[ -f "$db" ]] || continue
    tmp=$(mktemp)
    cp "$db" "$tmp" 2>/dev/null || { rm -f "$tmp"; continue; }
    val=$(sqlite3 "$tmp" \
      "SELECT value FROM moz_cookies WHERE host LIKE '%cursor.com%' AND name='WorkosCursorSessionToken' LIMIT 1" 2>/dev/null)
    rm -f "$tmp"
    [[ -n "$val" ]] && printf '%s' "$val" && return 0
  done
  return 1
}

# Extract WorkosCursorSessionToken from Chromium-based browser cookies (encrypted).
# Runs as a single Python process so the macOS keychain is prompted at most once
# per browser (keychain lookups are cached inside the script).
_cursor_cookie_chromium() {
  command -v python3 >/dev/null 2>&1 || return 1

  local os
  [[ "$OSTYPE" == darwin* ]] && os="Darwin" || os="Linux"

  python3 - "$os" "$HOME" <<'PYEOF'
import sys, os, glob, hashlib, subprocess, sqlite3, shutil, tempfile

os_name, home = sys.argv[1], sys.argv[2]

if os_name == 'Darwin':
    entries = [
        (os.path.join(home, 'Library/Application Support/Google/Chrome'),              'Chrome Safe Storage'),
        (os.path.join(home, 'Library/Application Support/Chromium'),                   'Chromium Safe Storage'),
        (os.path.join(home, 'Library/Application Support/Arc/User Data'),              'Arc Safe Storage'),
        (os.path.join(home, 'Library/Application Support/BraveSoftware/Brave-Browser'),'Brave Safe Storage'),
        (os.path.join(home, 'Library/Application Support/Microsoft Edge'),             'Microsoft Edge Safe Storage'),
        (os.path.join(home, 'Library/Application Support/net.imput.helium'),           'Helium Storage Key'),
    ]
else:
    entries = [
        (os.path.join(home, '.config/google-chrome'),   'v10'),
        (os.path.join(home, '.config/chromium'),        'v10'),
        (os.path.join(home, '.config/brave-browser'),   'v10'),
        (os.path.join(home, '.config/net.imput.helium'),'v10'),
    ]

# Cache keychain lookups so macOS prompts at most once per browser.
_keychain_cache = {}

def get_keychain_password(service):
    if service in _keychain_cache:
        return _keychain_cache[service]
    try:
        pw = subprocess.check_output(
            ['security', 'find-generic-password', '-s', service, '-w'],
            stderr=subprocess.DEVNULL).strip()
    except Exception:
        pw = None
    _keychain_cache[service] = pw
    return pw

def decrypt(enc_hex, key_service):
    enc = bytes.fromhex(enc_hex)
    if enc[:3] not in (b'v10', b'v11'):
        try: return enc.decode('utf-8').strip('\x00') or None
        except: return None
    version, ciphertext = enc[:3], enc[3:]
    if os_name == 'Darwin':
        password = get_keychain_password(key_service)
        if not password:
            return None
        key = hashlib.pbkdf2_hmac('sha1', password, b'saltysalt', 1003, dklen=16)
    else:
        if version == b'v11':
            return None  # requires secret-service; skip
        key = hashlib.pbkdf2_hmac('sha1', b'peanuts', b'saltysalt', 1, dklen=16)
    iv = b' ' * 16
    result = subprocess.run(
        ['openssl', 'enc', '-aes-128-cbc', '-d', '-nosalt',
         '-K', key.hex(), '-iv', iv.hex()],
        input=ciphertext, capture_output=True)
    if result.returncode != 0:
        return None
    # Some Chromium builds (e.g. ungoogled-chromium / Helium) prepend 32 random
    # bytes to the plaintext before encryption; try offset 0 first, then 32.
    for offset in (0, 32):
        try:
            val = result.stdout[offset:].decode('utf-8')
            if val:
                return val
        except (UnicodeDecodeError, ValueError):
            continue
    return None

for base_dir, key_service in entries:
    if not os.path.isdir(base_dir):
        continue
    for profile_dir in sorted(glob.glob(os.path.join(base_dir, '*'))):
        db = os.path.join(profile_dir, 'Cookies')
        if not os.path.isfile(db):
            continue
        tmp = None
        try:
            fd, tmp = tempfile.mkstemp()
            os.close(fd)
            shutil.copy2(db, tmp)
            conn = sqlite3.connect(tmp)
            row = conn.execute(
                "SELECT hex(encrypted_value) FROM cookies "
                "WHERE host_key LIKE '%cursor.com%' AND name='WorkosCursorSessionToken' LIMIT 1"
            ).fetchone()
            conn.close()
        except Exception:
            continue
        finally:
            if tmp and os.path.exists(tmp):
                os.unlink(tmp)
        if not row:
            continue
        val = decrypt(row[0], key_service)
        if val:
            print(val, end='')
            sys.exit(0)

sys.exit(1)
PYEOF
}

# Try all browsers; print the cookie value and return 0 on success.
get_cursor_cookie_from_browser() {
  local val
  val=$(_cursor_cookie_firefox 2>/dev/null) && [[ -n "$val" ]] && printf '%s' "$val" && return 0
  val=$(_cursor_cookie_chromium 2>/dev/null) && [[ -n "$val" ]] && printf '%s' "$val" && return 0
  return 1
}

# macOS: cookie cached in the login Keychain (encrypted by the OS).
#        -T /usr/bin/security grants the security CLI silent read access so
#        subsequent lookups never prompt.
# Linux: cookie cached in a 600-permission file (no libsecret dependency).
_CURSOR_KEYCHAIN_SERVICE="aiusage-cursor-session"
_CURSOR_COOKIE_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/aiusage/cursor_cookie"

_cursor_cache_read() {
  if [[ "$OSTYPE" == darwin* ]]; then
    security find-generic-password -s "$_CURSOR_KEYCHAIN_SERVICE" -a "$USER" -w 2>/dev/null
  else
    [[ -f "$_CURSOR_COOKIE_CACHE" ]] || return 1
    local now mtime age
    now=$(date +%s)
    mtime=$(stat -c %Y "$_CURSOR_COOKIE_CACHE" 2>/dev/null) || return 1
    age=$(( now - mtime ))
    (( age < 604800 )) || { rm -f "$_CURSOR_COOKIE_CACHE"; return 1; }
    cat "$_CURSOR_COOKIE_CACHE"
  fi
}

_cursor_cache_write() {
  if [[ "$OSTYPE" == darwin* ]]; then
    # -T /usr/bin/security: allow the security CLI to read this item without
    # a future confirmation dialog.  -U: update if the item already exists.
    security add-generic-password \
      -s "$_CURSOR_KEYCHAIN_SERVICE" -a "$USER" -w "$1" \
      -T /usr/bin/security -U 2>/dev/null || true
  else
    mkdir -p "$(dirname "$_CURSOR_COOKIE_CACHE")"
    printf '%s' "$1" > "$_CURSOR_COOKIE_CACHE"
    chmod 600 "$_CURSOR_COOKIE_CACHE"
  fi
}

_cursor_cache_clear() {
  if [[ "$OSTYPE" == darwin* ]]; then
    security delete-generic-password \
      -s "$_CURSOR_KEYCHAIN_SERVICE" -a "$USER" 2>/dev/null || true
  else
    rm -f "$_CURSOR_COOKIE_CACHE"
  fi
}

fetch_cursor() {
  local cookie="${CURSOR_COOKIE:-}"
  if [[ -z "$cookie" ]]; then
    cookie=$(_cursor_cache_read) || true
  fi
  if [[ -z "$cookie" ]]; then
    cookie=$(get_cursor_cookie_from_browser) || true
    [[ -n "$cookie" ]] && _cursor_cache_write "$cookie"
  fi
  if [[ -z "$cookie" ]]; then
    draw_error "no Cursor session found — set CURSOR_COOKIE or log in via a browser"
    return
  fi

  local cookie_hdr="Cookie: WorkosCursorSessionToken=$cookie"
  local _sf

  # Step 1: try modern usage-summary endpoint (current plans — credits-based)
  local sum_resp sum_status
  _sf=$(mktemp)
  sum_resp=$(HTTP_STATUS_FILE="$_sf" http_json \
    -H "$cookie_hdr" \
    -H "Accept: application/json" \
    "https://cursor.com/api/usage-summary")
  sum_status=$(cat "$_sf" 2>/dev/null || echo "000")
  rm -f "$_sf"

  if [[ "$sum_status" == 2* ]] && [[ -n "$sum_resp" ]]; then
    local plan_percent billing_end od_used od_limit
    IFS=$'\t' read -r plan_percent billing_end od_used od_limit < <(
      printf '%s' "$sum_resp" | jq -r '[
        (.individualUsage.plan.totalPercentUsed // ""),
        (.billingCycleEnd // ""),
        (.individualUsage.onDemand.used // ""),
        (.individualUsage.onDemand.limit // "")
      ] | @tsv' 2>/dev/null
    )

    if [[ -n "$plan_percent" && "$plan_percent" != "null" ]]; then
      local reset_epoch
      reset_epoch=$(normalize_epoch "$billing_end")
      draw_bar "Monthly" "${plan_percent%.*}"
      draw_reset "$reset_epoch"

      if [[ -n "$od_limit" && "$od_limit" != "0" && "$od_limit" != "null" ]]; then
        local od_percent
        od_percent=$(awk "BEGIN{printf \"%.0f\", (${od_used:-0} / $od_limit) * 100}" 2>/dev/null || echo 0)
        printf "\n"
        draw_bar "On-demand" "$od_percent"
        draw_credits_line "${od_used:-0}" "$od_limit"
      fi
      return
    fi
  fi

  # Step 2: fall back to legacy request-count endpoint — requires user ID
  local me_resp me_status user_id
  _sf=$(mktemp)
  me_resp=$(HTTP_STATUS_FILE="$_sf" http_json \
    -H "$cookie_hdr" \
    -H "Accept: application/json" \
    "https://cursor.com/api/auth/me")
  me_status=$(cat "$_sf" 2>/dev/null || echo "000")
  rm -f "$_sf"

  if [[ "$me_status" != 2* ]] || [[ -z "$me_resp" ]]; then
    case "$me_status" in
    401 | 403) _cursor_cache_clear; draw_error "session expired — re-login at cursor.com or update CURSOR_COOKIE" ;;
    000)       draw_error "network error or request timed out" ;;
    *)         draw_error "request failed (HTTP $me_status)" ;;
    esac
    return
  fi

  user_id=$(printf '%s' "$me_resp" | jq -r '.sub // empty' 2>/dev/null)
  if [[ -z "$user_id" ]]; then
    draw_error "could not retrieve usage data"
    return
  fi

  local usage_resp usage_status
  _sf=$(mktemp)
  usage_resp=$(HTTP_STATUS_FILE="$_sf" http_json \
    -H "$cookie_hdr" \
    -H "Accept: application/json" \
    "https://cursor.com/api/usage?user=$user_id")
  usage_status=$(cat "$_sf" 2>/dev/null || echo "000")
  rm -f "$_sf"

  if [[ "$usage_status" != 2* ]] || [[ -z "$usage_resp" ]]; then
    case "$usage_status" in
    401 | 403) _cursor_cache_clear; draw_error "session expired — re-login at cursor.com or update CURSOR_COOKIE" ;;
    000)       draw_error "network error or request timed out" ;;
    *)         draw_error "request failed (HTTP $usage_status)" ;;
    esac
    return
  fi

  local used limit
  IFS=$'\t' read -r used limit < <(
    printf '%s' "$usage_resp" | jq -r '[
      (.["gpt-4"].numRequests // ""),
      (.["gpt-4"].maxRequestUsage // "")
    ] | @tsv' 2>/dev/null
  )

  if [[ -z "$limit" || "$limit" == "0" || "$limit" == "null" ]]; then
    draw_error "no premium request quota found"
    return
  fi

  local percent
  percent=$(awk "BEGIN{printf \"%.0f\", (${used:-0} / $limit) * 100}" 2>/dev/null || echo 0)
  draw_bar "Monthly" "$percent"
  printf "  %-8s ${DIM}%s / %s requests${RESET}\n" "" "${used:-0}" "$limit"
}

