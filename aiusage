#!/usr/bin/env bash
set -euo pipefail

# ── config ──────────────────────────────────────────────
BAR_WIDTH=20
FILL="█"
EMPTY="░"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
DIM="\033[2m"
BOLD="\033[1m"
RESET="\033[0m"

# Disable ANSI escapes for non-interactive output and NO_COLOR terminals.
if [[ ! -t 1 || -n "${NO_COLOR:-}" || "${TERM:-}" == "dumb" ]]; then
  GREEN=""
  YELLOW=""
  RED=""
  DIM=""
  BOLD=""
  RESET=""
fi

# ── helpers ─────────────────────────────────────────────

draw_bar() {
  local label="$1" percent="$2"
  percent="${percent%.*}"
  [[ -z "$percent" ]] && percent=0
  ((percent < 0)) && percent=0
  ((percent > 100)) && percent=100

  local filled=$((percent * BAR_WIDTH / 100))
  local empty=$((BAR_WIDTH - filled))

  # pick color
  local color="$GREEN"
  ((percent >= 60)) && color="$YELLOW"
  ((percent >= 85)) && color="$RED"

  local bar="${color}"
  for ((i = 0; i < filled; i++)); do bar+="$FILL"; done
  bar+="${DIM}"
  for ((i = 0; i < empty; i++)); do bar+="$EMPTY"; done
  bar+="${RESET}"

  printf "  %-8s %b %3d%%\n" "$label" "$bar" "$percent"
}

draw_unavailable() {
  local label="$1"
  local bar="${DIM}"
  for ((i = 0; i < BAR_WIDTH; i++)); do bar+="$EMPTY"; done
  bar+="${RESET}"
  printf "  %-8s %b  --%%\n" "$label" "$bar"
}

draw_error() {
  local msg="$1"
  printf "  ${RED}error:${RESET} %s\n" "$msg"
}

draw_credits_line() {
  local used="$1" limit="$2"
  local used_fmt limit_fmt
  used_fmt=$(awk "BEGIN{printf \"%.2f\", $used/100}" 2>/dev/null || echo "$used")
  limit_fmt=$(awk "BEGIN{printf \"%.2f\", $limit/100}" 2>/dev/null || echo "$limit")
  printf "  %-8s ${DIM}\$%s / \$%s${RESET}\n" "" "$used_fmt" "$limit_fmt"
}

HTTP_STATUS="000"
HTTP_BODY=""
http_json() {
  local url="$1" body="$2"
  shift 2

  local tmp_body headers_file body_file="" status
  tmp_body=$(mktemp)
  headers_file=$(mktemp)
  chmod 600 "$headers_file" 2>/dev/null || true

  if (($# > 0)); then
    printf '%s\n' "$@" >"$headers_file"
  fi

  if [[ -n "$body" ]]; then
    body_file=$(mktemp)
    chmod 600 "$body_file" 2>/dev/null || true
    printf '%s' "$body" >"$body_file"
  fi

  local curl_args=(-s --max-time 10 -w "%{http_code}" -o "$tmp_body")
  [[ -s "$headers_file" ]] && curl_args+=(-H "@$headers_file")
  [[ -n "$body_file" ]] && curl_args+=(--data-binary "@$body_file")

  if ! status=$(curl "${curl_args[@]}" "$url" 2>/dev/null); then
    status="000"
  fi
  [[ "$status" =~ ^[0-9]{3}$ ]] || status="000"
  HTTP_STATUS="$status"
  HTTP_BODY=$(cat "$tmp_body")
  rm -f "$tmp_body" "$headers_file" "$body_file"
}

draw_http_error() {
  local status="$1" expired_msg="$2"
  case "$status" in
  401 | 403) draw_error "$expired_msg" ;;
  000) draw_error "network error or request timed out" ;;
  *) draw_error "request failed (HTTP $status)" ;;
  esac
}

ALL_PROVIDERS=(claude codex cursor gemini jetbrains)

provider_label() {
  case "$1" in
  claude) printf "Claude" ;;
  codex) printf "Codex" ;;
  cursor) printf "Cursor" ;;
  gemini) printf "Gemini" ;;
  jetbrains) printf "JetBrains" ;;
  *) return 1 ;;
  esac
}

provider_fetch_fn() {
  case "$1" in
  claude) printf "fetch_claude" ;;
  codex) printf "fetch_codex" ;;
  cursor) printf "fetch_cursor" ;;
  gemini) printf "fetch_gemini" ;;
  jetbrains) printf "fetch_jetbrains" ;;
  *) return 1 ;;
  esac
}

provider_is_known() {
  case "$1" in
  claude | codex | cursor | gemini | jetbrains) return 0 ;;
  *) return 1 ;;
  esac
}

provider_list_contains() {
  local needle="$1" item
  shift

  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done

  return 1
}

provider_unavailable_message() {
  case "$1" in
  claude) printf "claude is not installed" ;;
  codex) printf "codex is not installed" ;;
  cursor) printf "Cursor not available — set CURSOR_COOKIE or ensure a supported browser (Firefox/Chrome/Arc/Brave/Edge) with sqlite3 is present" ;;
  gemini) printf "gemini is not installed" ;;
  jetbrains) printf "jetbrains usage data is unavailable" ;;
  *) return 1 ;;
  esac
}

provider_available() {
  case "$1" in
  claude) command -v claude >/dev/null 2>&1 ;;
  codex) command -v codex >/dev/null 2>&1 ;;
  cursor) [[ -n "${CURSOR_COOKIE:-}" ]] || _cursor_has_browser ;;
  gemini) command -v gemini >/dev/null 2>&1 ;;
  jetbrains) [[ -n "$(find_jetbrains_quota_file)" ]] ;;
  *) return 1 ;;
  esac
}

find_jetbrains_quota_file() {
  local roots=()
  [[ -d "$HOME/Library/Application Support/JetBrains" ]] && roots+=("$HOME/Library/Application Support/JetBrains")
  [[ -d "${XDG_CONFIG_HOME:-$HOME/.config}/JetBrains" ]] && roots+=("${XDG_CONFIG_HOME:-$HOME/.config}/JetBrains")
  (( ${#roots[@]} == 0 )) && return 0

  local file newest_file="" newest_mtime=0 mtime
  while IFS= read -r file; do
    mtime=$(stat -f "%m" "$file" 2>/dev/null || stat -c "%Y" "$file" 2>/dev/null || echo 0)
    if ((mtime > newest_mtime)); then
      newest_mtime="$mtime"
      newest_file="$file"
    fi
  done < <(find "${roots[@]}" -path "*/options/AIAssistantQuotaManager2.xml" -type f 2>/dev/null)

  printf "%s" "$newest_file"
}

xml_unescape() {
  local value="${1:-}"
  value="${value//&quot;/\"}"
  value="${value//&#10;/$'\n'}"
  value="${value//&#13;/$'\r'}"
  value="${value//&apos;/\'}"
  value="${value//&lt;/<}"
  value="${value//&gt;/>}"
  value="${value//&amp;/&}"
  printf "%s" "$value"
}

duration_to_label() {
  local duration="${1:-}"
  if [[ "$duration" =~ ^PT([0-9]+)H$ ]]; then
    local hours="${BASH_REMATCH[1]}"
    if ((hours % 24 == 0)); then
      printf "%sd" "$((hours / 24))"
      return 0
    fi
    printf "%sh" "$hours"
    return 0
  fi

  if [[ "$duration" =~ ^P([0-9]+)D$ ]]; then
    printf "%sd" "${BASH_REMATCH[1]}"
    return 0
  fi

  printf "Credits"
}

normalize_epoch() {
  local raw="${1:-}"
  [[ -z "$raw" || "$raw" == "null" ]] && return 0

  if [[ "$raw" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    local int="${raw%%.*}"
    # Convert milliseconds to seconds when timestamps are too large.
    ((int > 100000000000)) && int=$((int / 1000))
    echo "$int"
    return 0
  fi

  # Claude often returns ISO timestamps with fractional seconds and/or offsets.
  # Normalize those variants and parse with local `date`.
  local cleaned
  cleaned=$(printf "%s" "$raw" | sed -E 's/([0-9])\.[0-9]+/\1/')
  if [[ "$cleaned" == *Z ]]; then
    cleaned="${cleaned%Z}+0000"
  fi
  cleaned=$(printf "%s" "$cleaned" | sed -E 's/([+-][0-9]{2}):([0-9]{2})$/\1\2/')

  if date -j -f "%Y-%m-%dT%H:%M:%S%z" "$cleaned" "+%s" >/dev/null 2>&1; then
    date -j -f "%Y-%m-%dT%H:%M:%S%z" "$cleaned" "+%s"
    return 0
  fi

  if date -j -f "%Y-%m-%dT%H:%M:%S" "$cleaned" "+%s" >/dev/null 2>&1; then
    date -j -f "%Y-%m-%dT%H:%M:%S" "$cleaned" "+%s"
    return 0
  fi

  # Linux/GNU fallback.
  date -d "$raw" "+%s" 2>/dev/null || true
}

format_epoch_local() {
  local epoch="${1:-}" mode="${2:-datetime}"
  [[ -z "$epoch" ]] && return 0

  local format="+%b %d %I:%M%p" value=""
  [[ "$mode" == "time" ]] && format="+%I:%M%p"

  if date -r "$epoch" "$format" >/dev/null 2>&1; then
    value=$(date -r "$epoch" "$format")
  else
    value=$(date -d "@$epoch" "$format" 2>/dev/null || true)
  fi

  if [[ "$mode" == "time" ]]; then
    value=$(printf "%s" "$value" | sed -E 's/^0//; s/AM$/am/; s/PM$/pm/')
  fi

  printf "%s" "$value"
}

format_remaining() {
  local seconds="${1:-}"
  [[ -z "$seconds" ]] && echo "unknown" && return 0

  if ((seconds <= 0)); then
    echo "now"
    return 0
  fi

  local days=$((seconds / 86400))
  local hours=$(((seconds % 86400) / 3600))
  local minutes=$(((seconds % 3600) / 60))

  if ((days > 0)); then
    printf "%dd %dh" "$days" "$hours"
  elif ((hours > 0)); then
    printf "%dh %dm" "$hours" "$minutes"
  else
    printf "%dm" "$minutes"
  fi
}

draw_reset() {
  local epoch="${1:-}" mode="${2:-datetime}"
  local reset_text="--"

  if [[ -n "$epoch" ]]; then
    local formatted now rel
    formatted=$(format_epoch_local "$epoch" "$mode")
    if [[ -n "$formatted" ]]; then
      now=$(date +%s)
      rel=$(format_remaining $((epoch - now)))
      reset_text="$formatted ($rel)"
    fi
  fi

  printf "  %-8s ${DIM}reset: %s${RESET}\n" "" "$reset_text"
}

SPINNER_FRAMES=('|' '/' '-' '\')
CURSOR_HIDDEN=0

spinner_frame() {
  local frame="${1:-0}"
  local idx=$((frame % ${#SPINNER_FRAMES[@]}))
  printf "%s" "${SPINNER_FRAMES[$idx]}"
}

hide_cursor() {
  if [[ -t 1 && $CURSOR_HIDDEN -eq 0 ]]; then
    printf "\033[?25l"
    CURSOR_HIDDEN=1
  fi
}

show_cursor() {
  if [[ -t 1 && $CURSOR_HIDDEN -eq 1 ]]; then
    printf "\033[?25h"
    CURSOR_HIDDEN=0
  fi
}

move_to_render_start() {
  local lines="${1:-0}"
  ((lines <= 0)) && return 0

  printf "\033[%dF" "$lines"
}

render_line() {
  printf "\033[2K%s\n" "$1"
}

render_heading_line() {
  printf "\033[2K%b%s%b\n" "$BOLD" "$1" "$RESET"
}

render_spinner_line() {
  printf "\033[2K%b%s%b %b%s%b\n" "$BOLD" "$1" "$RESET" "$DIM" "$2" "$RESET"
}

clear_extra_render_lines() {
  local lines="${1:-0}" i
  ((lines <= 0)) && return 0

  for ((i = 0; i < lines; i++)); do
    printf "\033[2K\n"
  done
}

SECTION_LINES=0
render_provider_section() {
  local label="$1" tmp_file="$2" done="$3" frame="$4"
  local lines=0

  if ((done)); then
    render_heading_line "$label"
    lines=1
    while IFS= read -r line || [[ -n "$line" ]]; do
      render_line "$line"
      ((lines++))
    done <"$tmp_file"
  else
    local spin
    spin=$(spinner_frame "$frame")
    render_spinner_line "$label" "$spin"
    lines=1
  fi

  SECTION_LINES="$lines"
}

RENDERED_LINES=0
WAIT_LABELS=()
WAIT_PIDS=()
WAIT_TMPS=()
WAIT_DONE=()

render_fetch_state() {
  local frame="$1" lines=0 i

  for ((i = 0; i < ${#WAIT_LABELS[@]}; i++)); do
    if ((i > 0)); then
      render_line ""
      ((lines++))
    fi
    render_provider_section "${WAIT_LABELS[$i]}" "${WAIT_TMPS[$i]}" "${WAIT_DONE[$i]:-0}" "$frame"
    lines=$((lines + SECTION_LINES))
  done

  RENDERED_LINES="$lines"
}

wait_and_render_fetches() {
  local frame=0 prev_lines=0 i done all_done

  hide_cursor
  while true; do
    WAIT_DONE=()
    all_done=1
    for ((i = 0; i < ${#WAIT_PIDS[@]}; i++)); do
      done=0
      kill -0 "${WAIT_PIDS[$i]}" 2>/dev/null || done=1
      WAIT_DONE+=("$done")
      ((done)) || all_done=0
    done

    if [[ -t 1 ]]; then
      move_to_render_start "$prev_lines"
      render_fetch_state "$frame"
      clear_extra_render_lines $((prev_lines - RENDERED_LINES))
      if ((RENDERED_LINES > prev_lines)); then
        prev_lines="$RENDERED_LINES"
      fi
    fi

    if ((all_done)); then
      break
    fi

    sleep 0.08
    frame=$((frame + 1))
  done

  for pid in "${WAIT_PIDS[@]}"; do
    wait "$pid" || true
  done

  if [[ ! -t 1 ]]; then
    WAIT_DONE=()
    for ((i = 0; i < ${#WAIT_LABELS[@]}; i++)); do
      WAIT_DONE+=(1)
    done
    render_fetch_state "$frame"
  fi

  show_cursor
}

cleanup_running_fetches() {
  local pid tmp
  show_cursor
  for pid in "${WAIT_PIDS[@]}"; do
    [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
  done
  for tmp in "${WAIT_TMPS[@]}"; do
    [[ -n "$tmp" ]] && rm -f "$tmp"
  done
}

start_provider_fetches() {
  local provider label fetch_fn tmp
  WAIT_LABELS=()
  WAIT_PIDS=()
  WAIT_TMPS=()
  WAIT_DONE=()

  for provider in "$@"; do
    label=$(provider_label "$provider")
    fetch_fn=$(provider_fetch_fn "$provider")
    tmp=$(mktemp)
    "$fetch_fn" >"$tmp" &
    WAIT_LABELS+=("$label")
    WAIT_PIDS+=("$!")
    WAIT_TMPS+=("$tmp")
  done
}

run_fetches_with_loading() {
  start_provider_fetches "$@"

  trap 'cleanup_running_fetches; trap - INT;  kill -INT  $$' INT
  trap 'cleanup_running_fetches; trap - TERM; kill -TERM $$' TERM
  trap 'cleanup_running_fetches' EXIT

  wait_and_render_fetches
  cleanup_running_fetches
  WAIT_LABELS=()
  WAIT_PIDS=()
  WAIT_TMPS=()
  WAIT_DONE=()
  trap - EXIT INT TERM
}

run_provider_with_loading() {
  run_fetches_with_loading "$1"
}

run_named_providers() {
  local selected=() unavailable=() provider unavailable_msg

  for provider in "$@"; do
    if (( ${#selected[@]} > 0 )) && provider_list_contains "$provider" "${selected[@]}"; then
      continue
    fi
    if (( ${#unavailable[@]} > 0 )) && provider_list_contains "$provider" "${unavailable[@]}"; then
      continue
    fi

    if provider_available "$provider"; then
      selected+=("$provider")
    else
      unavailable+=("$provider")
    fi
  done

  if (( ${#selected[@]} > 0 )); then
    run_fetches_with_loading "${selected[@]}"
  fi

  if (( ${#unavailable[@]} > 0 )); then
    for provider in "${unavailable[@]}"; do
      unavailable_msg=$(provider_unavailable_message "$provider")
      printf "%s\n" "$unavailable_msg" >&2
    done
  fi

  (( ${#selected[@]} > 0 ))
}

run_all_parallel() {
  local available=() provider provider_list

  for provider in "${ALL_PROVIDERS[@]}"; do
    if provider_available "$provider"; then
      available+=("$provider")
    fi
  done

  if (( ${#available[@]} == 0 )); then
    provider_list=$(printf "%s, " "${ALL_PROVIDERS[@]}")
    provider_list="${provider_list%, }"
    printf "No AI providers found (%s).\n" "$provider_list" >&2
    return 1
  fi
  run_fetches_with_loading "${available[@]}"
}

# ── claude ──────────────────────────────────────────────

fetch_claude() {
  local creds_file="$HOME/.claude/.credentials.json"
  local token=""

  if [[ -f "$creds_file" ]]; then
    token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds_file" 2>/dev/null)
  fi

  if [[ -z "$token" ]]; then
    # try macOS keychain
    token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null || true)
  fi

  if [[ -z "$token" ]]; then
    draw_error "not logged in run: claude /login"
    return
  fi

  local resp _status
  http_json \
    "https://api.anthropic.com/api/oauth/usage" "" \
    "Authorization: Bearer $token" \
    "anthropic-beta: oauth-2025-04-20" \
    "Accept: application/json"
  resp="$HTTP_BODY"
  _status="$HTTP_STATUS"

  if [[ "$_status" != 2* ]] || [[ -z "$resp" ]]; then
    draw_http_error "$_status" "session expired run: claude /login"
    return
  fi

  local five_hour seven_day five_hour_reset seven_day_reset
  IFS=$'\t' read -r five_hour seven_day five_hour_reset seven_day_reset < <(
    printf '%s' "$resp" | jq -r 'def first_reset(w): w.reset_at // w.resets_at // w.resetAt // w.resetsAt // w.window_end // w.window_end_at // w.windowEnd // w.windowEndAt;
      [(.five_hour.utilization // ""),
       (.seven_day.utilization // ""),
       (first_reset(.five_hour) // ""),
       (first_reset(.seven_day) // "")] | @tsv' 2>/dev/null
  )

  local five_hour_reset_epoch seven_day_reset_epoch
  five_hour_reset_epoch=$(normalize_epoch "$five_hour_reset")
  seven_day_reset_epoch=$(normalize_epoch "$seven_day_reset")

  if [[ -n "$five_hour" ]]; then
    draw_bar "5h" "${five_hour%.*}"
  else
    draw_unavailable "5h"
  fi
  draw_reset "$five_hour_reset_epoch" "time"

  if [[ -n "$seven_day" ]]; then
    draw_bar "Weekly" "${seven_day%.*}"
  else
    draw_unavailable "Weekly"
  fi
  draw_reset "$seven_day_reset_epoch"

  local extra_enabled extra_util extra_used extra_limit
  IFS=$'\t' read -r extra_enabled extra_util extra_used extra_limit < <(
    printf '%s' "$resp" | jq -r '[(.extra_usage.is_enabled // false | tostring),
       (.extra_usage.utilization // ""),
       (.extra_usage.used_credits // ""),
       (.extra_usage.monthly_limit // "")] | @tsv' 2>/dev/null
  )

  if [[ "$extra_enabled" == "true" && -n "$extra_limit" && "$extra_limit" != "0" && "$extra_limit" != "null" ]]; then
    printf "\n"
    if [[ -n "$extra_util" ]]; then
      draw_bar "Extra" "${extra_util%.*}"
    else
      draw_unavailable "Extra"
    fi
    draw_credits_line "${extra_used:-0}" "$extra_limit"
  fi
}

# ── codex ───────────────────────────────────────────────

fetch_codex() {
  local creds_file="${CODEX_HOME:-$HOME/.codex}/auth.json"
  local token="" account_id=""

  if [[ -f "$creds_file" ]]; then
    token=$(jq -r '.tokens.access_token // empty' "$creds_file" 2>/dev/null)
    account_id=$(jq -r '.tokens.account_id // empty' "$creds_file" 2>/dev/null)
  fi

  if [[ -z "$token" ]]; then
    draw_error "not logged in run: codex login"
    return
  fi

  local headers=("Authorization: Bearer $token" "Accept: application/json")
  [[ -n "$account_id" ]] && headers+=("ChatGPT-Account-Id: $account_id")

  local resp _status
  http_json "https://chatgpt.com/backend-api/wham/usage" "" "${headers[@]}"
  resp="$HTTP_BODY"
  _status="$HTTP_STATUS"

  if [[ "$_status" != 2* ]] || [[ -z "$resp" ]]; then
    draw_http_error "$_status" "session expired log in to Codex again"
    return
  fi

  local primary secondary primary_reset secondary_reset
  IFS=$'\t' read -r primary secondary primary_reset secondary_reset < <(
    printf '%s' "$resp" | jq -r 'def first_reset(w): w.reset_at // w.resets_at // w.resetAt // w.resetsAt // w.window_end // w.window_end_at // w.windowEnd // w.windowEndAt;
      [(.rate_limit.primary_window.used_percent // ""),
       (.rate_limit.secondary_window.used_percent // ""),
       (first_reset(.rate_limit.primary_window) // ""),
       (first_reset(.rate_limit.secondary_window) // "")] | @tsv' 2>/dev/null
  )

  local primary_reset_epoch secondary_reset_epoch
  primary_reset_epoch=$(normalize_epoch "$primary_reset")
  secondary_reset_epoch=$(normalize_epoch "$secondary_reset")

  if [[ -n "$primary" ]]; then
    draw_bar "5h" "$primary"
  else
    draw_unavailable "5h"
  fi
  draw_reset "$primary_reset_epoch" "time"

  if [[ -n "$secondary" ]]; then
    draw_bar "Weekly" "$secondary"
  else
    draw_unavailable "Weekly"
  fi
  draw_reset "$secondary_reset_epoch"
}

# ── cursor ──────────────────────────────────────────────

# Fast check: is any supported browser with sqlite3 present?
_cursor_has_browser() {
  command -v sqlite3 >/dev/null 2>&1 || return 1
  local has_firefox=0 has_chromium=0

  if [[ "$OSTYPE" == darwin* ]]; then
    [[ -d "$HOME/Library/Application Support/Firefox/Profiles" ]] && has_firefox=1
    [[ -d "$HOME/Library/Application Support/Google/Chrome" ]] && has_chromium=1
    [[ -d "$HOME/Library/Application Support/Chromium" ]] && has_chromium=1
    [[ -d "$HOME/Library/Application Support/Arc" ]] && has_chromium=1
    [[ -d "$HOME/Library/Application Support/BraveSoftware" ]] && has_chromium=1
    [[ -d "$HOME/Library/Application Support/Microsoft Edge" ]] && has_chromium=1
    [[ -d "$HOME/Library/Application Support/net.imput.helium" ]] && has_chromium=1
  else
    [[ -d "$HOME/.mozilla/firefox" ]] && has_firefox=1
    [[ -d "$HOME/.config/google-chrome" ]] && has_chromium=1
    [[ -d "$HOME/.config/chromium" ]] && has_chromium=1
    [[ -d "$HOME/.config/brave-browser" ]] && has_chromium=1
    [[ -d "$HOME/.config/net.imput.helium" ]] && has_chromium=1
  fi

  ((has_firefox)) && return 0
  ((has_chromium)) || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  command -v openssl >/dev/null 2>&1
}

# Extract WorkosCursorSessionToken from Firefox cookies.sqlite (unencrypted)
_cursor_cookie_firefox() {
  command -v sqlite3 >/dev/null 2>&1 || return 1
  local profiles_dir
  if [[ "$OSTYPE" == darwin* ]]; then
    profiles_dir="$HOME/Library/Application Support/Firefox/Profiles"
  else
    profiles_dir="$HOME/.mozilla/firefox"
  fi
  [[ -d "$profiles_dir" ]] || return 1

  local profile db tmp val
  for profile in "$profiles_dir"/*/; do
    db="$profile/cookies.sqlite"
    [[ -f "$db" ]] || continue
    tmp=$(mktemp)
    cp "$db" "$tmp" 2>/dev/null || { rm -f "$tmp"; continue; }
    val=$(sqlite3 "$tmp" \
      "SELECT value FROM moz_cookies WHERE host LIKE '%cursor.com%' AND name='WorkosCursorSessionToken' LIMIT 1" 2>/dev/null)
    rm -f "$tmp"
    [[ -n "$val" ]] && printf '%s' "$val" && return 0
  done
  return 1
}

# Extract WorkosCursorSessionToken from Chromium-based browser cookies (encrypted).
# Runs as a single Python process so the macOS keychain is prompted at most once
# per browser (keychain lookups are cached inside the script).
_cursor_cookie_chromium() {
  command -v python3 >/dev/null 2>&1 || return 1

  local os
  [[ "$OSTYPE" == darwin* ]] && os="Darwin" || os="Linux"

  python3 - "$os" "$HOME" <<'PYEOF'
import sys, os, glob, hashlib, subprocess, sqlite3, shutil, tempfile

os_name, home = sys.argv[1], sys.argv[2]

if os_name == 'Darwin':
    entries = [
        (os.path.join(home, 'Library/Application Support/Google/Chrome'),              'Chrome Safe Storage'),
        (os.path.join(home, 'Library/Application Support/Chromium'),                   'Chromium Safe Storage'),
        (os.path.join(home, 'Library/Application Support/Arc/User Data'),              'Arc Safe Storage'),
        (os.path.join(home, 'Library/Application Support/BraveSoftware/Brave-Browser'),'Brave Safe Storage'),
        (os.path.join(home, 'Library/Application Support/Microsoft Edge'),             'Microsoft Edge Safe Storage'),
        (os.path.join(home, 'Library/Application Support/net.imput.helium'),           'Helium Storage Key'),
    ]
else:
    entries = [
        (os.path.join(home, '.config/google-chrome'),   'v10'),
        (os.path.join(home, '.config/chromium'),        'v10'),
        (os.path.join(home, '.config/brave-browser'),   'v10'),
        (os.path.join(home, '.config/net.imput.helium'),'v10'),
    ]

# Cache keychain lookups so macOS prompts at most once per browser.
_keychain_cache = {}

def get_keychain_password(service):
    if service in _keychain_cache:
        return _keychain_cache[service]
    try:
        pw = subprocess.check_output(
            ['security', 'find-generic-password', '-s', service, '-w'],
            stderr=subprocess.DEVNULL).strip()
    except Exception:
        pw = None
    _keychain_cache[service] = pw
    return pw

def decrypt(enc_hex, key_service):
    enc = bytes.fromhex(enc_hex)
    if enc[:3] not in (b'v10', b'v11'):
        try: return enc.decode('utf-8').strip('\x00') or None
        except: return None
    version, ciphertext = enc[:3], enc[3:]
    if os_name == 'Darwin':
        password = get_keychain_password(key_service)
        if not password:
            return None
        key = hashlib.pbkdf2_hmac('sha1', password, b'saltysalt', 1003, dklen=16)
    else:
        if version == b'v11':
            return None  # requires secret-service; skip
        key = hashlib.pbkdf2_hmac('sha1', b'peanuts', b'saltysalt', 1, dklen=16)
    iv = b' ' * 16
    result = subprocess.run(
        ['openssl', 'enc', '-aes-128-cbc', '-d', '-nosalt',
         '-K', key.hex(), '-iv', iv.hex()],
        input=ciphertext, capture_output=True)
    if result.returncode != 0:
        return None
    # Some Chromium builds (e.g. ungoogled-chromium / Helium) prepend 32 random
    # bytes to the plaintext before encryption; try offset 0 first, then 32.
    for offset in (0, 32):
        try:
            val = result.stdout[offset:].decode('utf-8')
            if val:
                return val
        except (UnicodeDecodeError, ValueError):
            continue
    return None

for base_dir, key_service in entries:
    if not os.path.isdir(base_dir):
        continue
    for profile_dir in sorted(glob.glob(os.path.join(base_dir, '*'))):
        db = os.path.join(profile_dir, 'Cookies')
        if not os.path.isfile(db):
            continue
        tmp = None
        try:
            fd, tmp = tempfile.mkstemp()
            os.close(fd)
            shutil.copy2(db, tmp)
            conn = sqlite3.connect(tmp)
            row = conn.execute(
                "SELECT hex(encrypted_value) FROM cookies "
                "WHERE host_key LIKE '%cursor.com%' AND name='WorkosCursorSessionToken' LIMIT 1"
            ).fetchone()
            conn.close()
        except Exception:
            continue
        finally:
            if tmp and os.path.exists(tmp):
                os.unlink(tmp)
        if not row:
            continue
        val = decrypt(row[0], key_service)
        if val:
            print(val, end='')
            sys.exit(0)

sys.exit(1)
PYEOF
}

# Try all browsers; print the cookie value and return 0 on success.
get_cursor_cookie_from_browser() {
  local val
  val=$(_cursor_cookie_firefox 2>/dev/null) && [[ -n "$val" ]] && printf '%s' "$val" && return 0
  val=$(_cursor_cookie_chromium 2>/dev/null) && [[ -n "$val" ]] && printf '%s' "$val" && return 0
  return 1
}

# macOS: cookie cached in the login Keychain (encrypted by the OS).
# Linux: cookie cached in a 600-permission file (no libsecret dependency).
_CURSOR_KEYCHAIN_SERVICE="aiusage-cursor-session"
_CURSOR_COOKIE_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/aiusage/cursor_cookie"

_cursor_cache_read() {
  if [[ "$OSTYPE" == darwin* ]]; then
    security find-generic-password -s "$_CURSOR_KEYCHAIN_SERVICE" -a "$USER" -w 2>/dev/null
  else
    [[ -f "$_CURSOR_COOKIE_CACHE" ]] || return 1
    local now mtime age
    now=$(date +%s)
    mtime=$(stat -c %Y "$_CURSOR_COOKIE_CACHE" 2>/dev/null) || return 1
    age=$(( now - mtime ))
    (( age < 604800 )) || { rm -f "$_CURSOR_COOKIE_CACHE"; return 1; }
    cat "$_CURSOR_COOKIE_CACHE"
  fi
}

_cursor_cache_write() {
  if [[ "$OSTYPE" == darwin* ]]; then
    # Keep the default keychain access controls so future reads still require
    # the user's normal approval policy. -U updates the existing item in place.
    security add-generic-password \
      -s "$_CURSOR_KEYCHAIN_SERVICE" -a "$USER" -w "$1" \
      -U 2>/dev/null || true
  else
    mkdir -p "$(dirname "$_CURSOR_COOKIE_CACHE")"
    printf '%s' "$1" > "$_CURSOR_COOKIE_CACHE"
    chmod 600 "$_CURSOR_COOKIE_CACHE"
  fi
}

_cursor_cache_clear() {
  if [[ "$OSTYPE" == darwin* ]]; then
    security delete-generic-password \
      -s "$_CURSOR_KEYCHAIN_SERVICE" -a "$USER" 2>/dev/null || true
  else
    rm -f "$_CURSOR_COOKIE_CACHE"
  fi
}

fetch_cursor() {
  local cookie="${CURSOR_COOKIE:-}"
  if [[ -z "$cookie" ]]; then
    cookie=$(_cursor_cache_read) || true
  fi
  if [[ -z "$cookie" ]]; then
    cookie=$(get_cursor_cookie_from_browser) || true
    [[ -n "$cookie" ]] && _cursor_cache_write "$cookie"
  fi
  if [[ -z "$cookie" ]]; then
    draw_error "no Cursor session found — set CURSOR_COOKIE or log in via a browser"
    return
  fi

  local cookie_hdr="Cookie: WorkosCursorSessionToken=$cookie"

  # Step 1: try modern usage-summary endpoint (current plans — credits-based)
  local sum_resp sum_status
  http_json \
    "https://cursor.com/api/usage-summary" "" \
    "$cookie_hdr" \
    "Accept: application/json"
  sum_resp="$HTTP_BODY"
  sum_status="$HTTP_STATUS"

  if [[ "$sum_status" == 2* ]] && [[ -n "$sum_resp" ]]; then
    local plan_percent billing_end od_used od_limit
    IFS=$'\t' read -r plan_percent billing_end od_used od_limit < <(
      printf '%s' "$sum_resp" | jq -r '[
        (.individualUsage.plan.totalPercentUsed // ""),
        (.billingCycleEnd // ""),
        (.individualUsage.onDemand.used // ""),
        (.individualUsage.onDemand.limit // "")
      ] | @tsv' 2>/dev/null
    )

    if [[ -n "$plan_percent" && "$plan_percent" != "null" ]]; then
      local reset_epoch
      reset_epoch=$(normalize_epoch "$billing_end")
      draw_bar "Monthly" "${plan_percent%.*}"
      draw_reset "$reset_epoch"

      if [[ -n "$od_limit" && "$od_limit" != "0" && "$od_limit" != "null" ]]; then
        local od_percent
        od_percent=$(awk "BEGIN{printf \"%.0f\", (${od_used:-0} / $od_limit) * 100}" 2>/dev/null || echo 0)
        printf "\n"
        draw_bar "On-demand" "$od_percent"
        draw_credits_line "${od_used:-0}" "$od_limit"
      fi
      return
    fi
  fi

  # Step 2: fall back to legacy request-count endpoint — requires user ID
  local me_resp me_status user_id
  http_json \
    "https://cursor.com/api/auth/me" "" \
    "$cookie_hdr" \
    "Accept: application/json"
  me_resp="$HTTP_BODY"
  me_status="$HTTP_STATUS"

  if [[ "$me_status" != 2* ]] || [[ -z "$me_resp" ]]; then
    [[ "$me_status" == "401" || "$me_status" == "403" ]] && _cursor_cache_clear
    draw_http_error "$me_status" "session expired — re-login at cursor.com or update CURSOR_COOKIE"
    return
  fi

  user_id=$(printf '%s' "$me_resp" | jq -r '.sub // empty' 2>/dev/null)
  if [[ -z "$user_id" ]]; then
    draw_error "could not retrieve usage data"
    return
  fi

  local usage_resp usage_status
  http_json \
    "https://cursor.com/api/usage?user=$user_id" "" \
    "$cookie_hdr" \
    "Accept: application/json"
  usage_resp="$HTTP_BODY"
  usage_status="$HTTP_STATUS"

  if [[ "$usage_status" != 2* ]] || [[ -z "$usage_resp" ]]; then
    [[ "$usage_status" == "401" || "$usage_status" == "403" ]] && _cursor_cache_clear
    draw_http_error "$usage_status" "session expired — re-login at cursor.com or update CURSOR_COOKIE"
    return
  fi

  local used limit
  IFS=$'\t' read -r used limit < <(
    printf '%s' "$usage_resp" | jq -r '[
      (.["gpt-4"].numRequests // ""),
      (.["gpt-4"].maxRequestUsage // "")
    ] | @tsv' 2>/dev/null
  )

  if [[ -z "$limit" || "$limit" == "0" || "$limit" == "null" ]]; then
    draw_error "no premium request quota found"
    return
  fi

  local percent
  percent=$(awk "BEGIN{printf \"%.0f\", (${used:-0} / $limit) * 100}" 2>/dev/null || echo 0)
  draw_bar "Monthly" "$percent"
  printf "  %-8s ${DIM}%s / %s requests${RESET}\n" "" "${used:-0}" "$limit"
}

# ── gemini ──────────────────────────────────────────────

gemini_bucket_info() {
  case "$1" in
  gemini-2.5-flash)       printf '10\tFlash'  ;;
  gemini-2.5-pro)         printf '20\tPro'    ;;
  gemini-3-flash-preview) printf '30\tPreview' ;;
  gemini-3-pro-preview)   printf '30\tPreview' ;;
  gemini-2.5-flash-lite)  printf '50\tLite'   ;;
  *)                      printf '99\t%s' "$1" ;;
  esac
}

fetch_gemini() {
  local creds_file="$HOME/.gemini/oauth_creds.json"
  local access_token="" expiry_date=""

  if [[ -f "$creds_file" ]]; then
    local _creds
    _creds=$(jq -r '[.access_token // "", .expiry_date // ""] | @tsv' "$creds_file" 2>/dev/null)
    IFS=$'\t' read -r access_token expiry_date <<<"$_creds"
  fi

  if [[ -z "$access_token" ]]; then
    draw_error "not logged in run: gemini"
    return
  fi

  local now
  now=$(date +%s)
  if [[ -n "$expiry_date" && "$expiry_date" =~ ^[0-9]+$ ]]; then
    if ((expiry_date / 1000 <= now + 60)); then
      draw_error "session expired run: gemini"
      return
    fi
  fi

  local project_hint load_body load_resp project_id quota_body quota_resp
  local load_status quota_status
  project_hint="${GOOGLE_CLOUD_PROJECT:-${GOOGLE_CLOUD_PROJECT_ID:-}}"

  load_body=$(jq -cn --arg project_hint "$project_hint" '
    {
      metadata: {
        ideType: "IDE_UNSPECIFIED",
        platform: "PLATFORM_UNSPECIFIED",
        pluginType: "GEMINI"
      }
    } + (if $project_hint == "" then {} else {cloudaicompanionProject: $project_hint} end)
  ' 2>/dev/null)
  http_json \
    "https://cloudcode-pa.googleapis.com/v1internal:loadCodeAssist" "$load_body" \
    "Authorization: Bearer $access_token" \
    "Content-Type: application/json"
  load_resp="$HTTP_BODY"
  load_status="$HTTP_STATUS"

  if [[ "$load_status" != 2* ]] || [[ -z "$load_resp" ]]; then
    draw_http_error "$load_status" "session expired run: gemini"
    return
  fi

  project_id=$(printf '%s' "$load_resp" | jq -r '.cloudaicompanionProject // empty' 2>/dev/null)
  [[ -z "$project_id" && -n "$project_hint" ]] && project_id="$project_hint"

  if [[ -z "$project_id" ]]; then
    local validation_url
    validation_url=$(printf '%s' "$load_resp" | jq -r '.ineligibleTiers[]?.validationUrl // empty' 2>/dev/null | head -n1)
    if [[ -n "$validation_url" ]]; then
      draw_error "validation required see: $validation_url"
    else
      draw_error "Gemini project/quota is unavailable"
    fi
    return
  fi

  quota_body=$(jq -cn --arg project_id "$project_id" '{project: $project_id}' 2>/dev/null)
  http_json \
    "https://cloudcode-pa.googleapis.com/v1internal:retrieveUserQuota" "$quota_body" \
    "Authorization: Bearer $access_token" \
    "Content-Type: application/json"
  quota_resp="$HTTP_BODY"
  quota_status="$HTTP_STATUS"

  if [[ "$quota_status" != 2* ]] || [[ -z "$quota_resp" ]]; then
    draw_http_error "$quota_status" "session expired run: gemini"
    return
  fi

  local bucket_rows=()
  while IFS=$'\t' read -r model_id percent reset_time; do
    [[ -z "$model_id" ]] && continue
    local _info _order _label
    IFS=$'\t' read -r _order _label <<<"$(gemini_bucket_info "$model_id")"
    bucket_rows+=("$_order"$'\t'"$_label"$'\t'"$percent"$'\t'"$reset_time")
  done < <(
    printf '%s' "$quota_resp" | jq -r '.buckets[]? | [.modelId // "", (((1 - (.remainingFraction // 1)) * 100) | round | tostring), .resetTime // ""] | @tsv' 2>/dev/null
  )

  if (( ${#bucket_rows[@]} == 0 )); then
    draw_error "Gemini quota data is unavailable"
    return
  fi

  local summary_percent=-1 summary_reset_epoch="" detail_line=""
  local grouped_rows
  grouped_rows=$(printf '%s\n' "${bucket_rows[@]}" | sort -t $'\t' -k1,1n | awk -F '\t' '
    {
      label=$2
      percent=$3 + 0
      reset=$4
      if (!(label in max) || percent > max[label]) {
        max[label]=percent
      }
      if (!(label in latest) || reset > latest[label]) {
        latest[label]=reset
      }
      if (!(label in ord)) {
        ord[label]=$1 + 0
        labels[++count]=label
      }
    }
    END {
      for (i=1; i<=count; i++) {
        label=labels[i]
        printf "%d\t%s\t%d\t%s\n", ord[label], label, max[label], latest[label]
      }
    }')

  local order label percent reset_time reset_epoch
  while IFS=$'\t' read -r order label percent reset_time; do
    [[ -n "$order" ]] || continue

    if (( summary_percent < 0 || percent > summary_percent )); then
      summary_percent=$percent
    fi

    reset_epoch=$(normalize_epoch "$reset_time")
    if [[ -n "$reset_epoch" ]] && (( reset_epoch > ${summary_reset_epoch:-0} )); then
      summary_reset_epoch="$reset_epoch"
    fi

    if [[ -n "$detail_line" ]]; then
      detail_line+="  "
    fi
    detail_line+="$label ${percent}%"
  done <<<"$grouped_rows"

  if (( summary_percent >= 0 )); then
    draw_bar "Daily" "$summary_percent"
  else
    draw_unavailable "Daily"
  fi
  draw_reset "$summary_reset_epoch"

  if [[ -n "$detail_line" ]]; then
    printf "  %-8s ${DIM}detail: %s${RESET}\n" "" "$detail_line"
  fi

}

# ── jetbrains ───────────────────────────────────────────

fetch_jetbrains() {
  local quota_file quota_info next_refill
  quota_file=$(find_jetbrains_quota_file)

  # JetBrains reads from a local file and can complete before the spinner paints.
  # Keep a brief delay so its loading state is visible like the network-backed providers.
  sleep 0.25

  if [[ -z "$quota_file" || ! -f "$quota_file" ]]; then
    draw_error "no JetBrains AI quota file found"
    return
  fi

  local raw_quota_info raw_next_refill quota_row
  quota_row=$(
    awk '
      /name="quotaInfo"/ && match($0, /value="[^"]*"/) {
        qi = substr($0, RSTART + 7, RLENGTH - 8)
      }
      /name="nextRefill"/ && match($0, /value="[^"]*"/) {
        nr = substr($0, RSTART + 7, RLENGTH - 8)
      }
      END { printf "%s\t%s\n", qi, nr }
    ' "$quota_file"
  )
  IFS=$'\t' read -r raw_quota_info raw_next_refill <<<"$quota_row"
  quota_info=$(xml_unescape "$raw_quota_info")
  next_refill=$(xml_unescape "$raw_next_refill")

  if [[ -z "$quota_info" ]]; then
    draw_error "JetBrains quota info is unavailable"
    return
  fi

  local current maximum until topup_current topup_max duration quota_values
  quota_values=$(
    {
      printf '%s' "$quota_info" | jq -r '[
        (.current // ""),
        (.maximum // ""),
        (.until // ""),
        (.topUpQuota.current // ""),
        (.topUpQuota.maximum // "")
      ] | @tsv' 2>/dev/null
      printf '\t'
      printf '%s' "$next_refill" | jq -r '.tariff.duration // ""' 2>/dev/null
      printf '\n'
    }
  )
  IFS=$'\t' read -r current maximum until topup_current topup_max duration <<<"$quota_values"

  if [[ -z "$maximum" || "$maximum" == "0" || "$maximum" == "null" ]]; then
    draw_error "JetBrains quota limit is unavailable"
    return
  fi

  local percent reset_epoch label
  percent=$(awk "BEGIN{printf \"%.0f\", ($current / $maximum) * 100}" 2>/dev/null || true)
  reset_epoch=$(normalize_epoch "$until")
  label=$(duration_to_label "$duration")

  if [[ -n "$percent" ]]; then
    draw_bar "$label" "$percent"
  else
    draw_unavailable "$label"
  fi
  draw_reset "$reset_epoch"

  printf "  %-8s ${DIM}%s / %s credits${RESET}\n" "" "${current%.*}" "${maximum%.*}"

  if [[ -n "$topup_max" && "$topup_max" != "0" && "$topup_max" != "null" ]]; then
    local topup_percent
    topup_percent=$(awk "BEGIN{printf \"%.0f\", ($topup_current / $topup_max) * 100}" 2>/dev/null || true)
    printf "\n"
    if [[ -n "$topup_percent" ]]; then
      draw_bar "Top-up" "$topup_percent"
    else
      draw_unavailable "Top-up"
    fi
    printf "  %-8s ${DIM}%s / %s credits${RESET}\n" "" "${topup_current%.*}" "${topup_max%.*}"
  fi
}

# ── main ────────────────────────────────────────────────

usage() {
  cat <<'EOF'
Usage: aiusage [provider ...]

Providers:
  claude    Show Claude usage
  codex     Show Codex usage
  cursor    Show Cursor usage (auto-detects from browser or CURSOR_COOKIE)
  gemini    Show Gemini CLI usage
  jetbrains Show JetBrains AI usage

Pass one or more providers to print only those sections.
Omit provider, or pass 'all', to print all detected providers.
EOF
}

run_from_args() {
  local requested=() arg exit_code=0
  local run_all=0

  if (($# == 0)); then
    run_all_parallel
    return
  fi

  for arg in "$@"; do
    case "$arg" in
    -h | --help | help)
      usage
      return
      ;;
    all)
      run_all=1
      ;;
    *)
      if ! provider_is_known "$arg"; then
        printf "Unknown provider: %s\n\n" "$arg" >&2
        usage >&2
        return 1
      fi

      if (( ${#requested[@]} == 0 )) || ! provider_list_contains "$arg" "${requested[@]}"; then
        requested+=("$arg")
      fi
      ;;
    esac
  done

  if ((run_all)); then
    run_all_parallel
    return
  fi

  if ! run_named_providers "${requested[@]}"; then
    exit_code=1
  fi

  return "$exit_code"
}

run_from_args "$@"

printf "\n"
