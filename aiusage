#!/usr/bin/env bash
set -euo pipefail

# ── config ──────────────────────────────────────────────
BAR_WIDTH=20
FILL="█"
EMPTY="░"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
DIM="\033[2m"
BOLD="\033[1m"
RESET="\033[0m"

# Disable ANSI escapes for non-interactive output and NO_COLOR terminals.
if [[ ! -t 1 || -n "${NO_COLOR:-}" || "${TERM:-}" == "dumb" ]]; then
  GREEN=""
  YELLOW=""
  RED=""
  DIM=""
  BOLD=""
  RESET=""
fi

# ── helpers ─────────────────────────────────────────────

draw_bar() {
  local label="$1" percent="$2"
  percent="${percent%.*}"
  [[ -z "$percent" ]] && percent=0
  ((percent < 0)) && percent=0
  ((percent > 100)) && percent=100

  local filled=$((percent * BAR_WIDTH / 100))
  local empty=$((BAR_WIDTH - filled))

  # pick color
  local color="$GREEN"
  ((percent >= 60)) && color="$YELLOW"
  ((percent >= 85)) && color="$RED"

  local bar="${color}"
  for ((i = 0; i < filled; i++)); do bar+="$FILL"; done
  bar+="${DIM}"
  for ((i = 0; i < empty; i++)); do bar+="$EMPTY"; done
  bar+="${RESET}"

  printf "  %-8s %b %3d%%\n" "$label" "$bar" "$percent"
}

draw_unavailable() {
  local label="$1"
  local bar="${DIM}"
  for ((i = 0; i < BAR_WIDTH; i++)); do bar+="$EMPTY"; done
  bar+="${RESET}"
  printf "  %-8s %b  --%%\n" "$label" "$bar"
}

draw_error() {
  local msg="$1"
  printf "  ${RED}error:${RESET} %s\n" "$msg"
}

draw_credits_line() {
  local used="$1" limit="$2"
  local used_fmt limit_fmt
  used_fmt=$(awk "BEGIN{printf \"%.2f\", $used/100}" 2>/dev/null || echo "$used")
  limit_fmt=$(awk "BEGIN{printf \"%.2f\", $limit/100}" 2>/dev/null || echo "$limit")
  printf "  %-8s ${DIM}\$%s / \$%s${RESET}\n" "" "$used_fmt" "$limit_fmt"
}

http_json() {
  local tmp_body status
  tmp_body=$(mktemp)

  if ! status=$(curl -s --max-time 10 -w "%{http_code}" -o "$tmp_body" "$@" 2>/dev/null); then
    status="000"
  fi
  [[ "$status" =~ ^[0-9]{3}$ ]] || status="000"

  [[ -n "${HTTP_STATUS_FILE:-}" ]] && printf "%s" "$status" >"$HTTP_STATUS_FILE"
  cat "$tmp_body"
  rm -f "$tmp_body"
}

provider_available() {
  case "$1" in
  claude) command -v claude >/dev/null 2>&1 ;;
  codex) command -v codex >/dev/null 2>&1 ;;
  gemini) command -v gemini >/dev/null 2>&1 ;;
  jetbrains) [[ -n "$(find_jetbrains_quota_file)" ]] ;;
  *) return 1 ;;
  esac
}

find_jetbrains_quota_file() {
  local roots=()
  [[ -d "$HOME/Library/Application Support/JetBrains" ]] && roots+=("$HOME/Library/Application Support/JetBrains")
  [[ -d "${XDG_CONFIG_HOME:-$HOME/.config}/JetBrains" ]] && roots+=("${XDG_CONFIG_HOME:-$HOME/.config}/JetBrains")
  (( ${#roots[@]} == 0 )) && return 0

  local file newest_file="" newest_mtime=0 mtime
  while IFS= read -r file; do
    mtime=$(stat -f "%m" "$file" 2>/dev/null || stat -c "%Y" "$file" 2>/dev/null || echo 0)
    if ((mtime > newest_mtime)); then
      newest_mtime="$mtime"
      newest_file="$file"
    fi
  done < <(find "${roots[@]}" -path "*/options/AIAssistantQuotaManager2.xml" -type f 2>/dev/null)

  printf "%s" "$newest_file"
}

xml_unescape() {
  local value="${1:-}"
  value="${value//&quot;/\"}"
  value="${value//&#10;/$'\n'}"
  value="${value//&#13;/$'\r'}"
  value="${value//&apos;/\'}"
  value="${value//&lt;/<}"
  value="${value//&gt;/>}"
  value="${value//&amp;/&}"
  printf "%s" "$value"
}

duration_to_label() {
  local duration="${1:-}"
  if [[ "$duration" =~ ^PT([0-9]+)H$ ]]; then
    local hours="${BASH_REMATCH[1]}"
    if ((hours % 24 == 0)); then
      printf "%sd" "$((hours / 24))"
      return 0
    fi
    printf "%sh" "$hours"
    return 0
  fi

  if [[ "$duration" =~ ^P([0-9]+)D$ ]]; then
    printf "%sd" "${BASH_REMATCH[1]}"
    return 0
  fi

  printf "Credits"
}

normalize_epoch() {
  local raw="${1:-}"
  [[ -z "$raw" || "$raw" == "null" ]] && return 0

  if [[ "$raw" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    local int="${raw%%.*}"
    # Convert milliseconds to seconds when timestamps are too large.
    ((int > 100000000000)) && int=$((int / 1000))
    echo "$int"
    return 0
  fi

  # Claude often returns ISO timestamps with fractional seconds and/or offsets.
  # Normalize those variants and parse with local `date`.
  local cleaned
  cleaned=$(printf "%s" "$raw" | sed -E 's/([0-9])\.[0-9]+/\1/')
  if [[ "$cleaned" == *Z ]]; then
    cleaned="${cleaned%Z}+0000"
  fi
  cleaned=$(printf "%s" "$cleaned" | sed -E 's/([+-][0-9]{2}):([0-9]{2})$/\1\2/')

  if date -j -f "%Y-%m-%dT%H:%M:%S%z" "$cleaned" "+%s" >/dev/null 2>&1; then
    date -j -f "%Y-%m-%dT%H:%M:%S%z" "$cleaned" "+%s"
    return 0
  fi

  if date -j -f "%Y-%m-%dT%H:%M:%S" "$cleaned" "+%s" >/dev/null 2>&1; then
    date -j -f "%Y-%m-%dT%H:%M:%S" "$cleaned" "+%s"
    return 0
  fi

  # Linux/GNU fallback.
  date -d "$raw" "+%s" 2>/dev/null || true
}

format_epoch_local() {
  local epoch="${1:-}" mode="${2:-datetime}"
  [[ -z "$epoch" ]] && return 0

  local format="+%b %d %I:%M%p" value=""
  [[ "$mode" == "time" ]] && format="+%I:%M%p"

  if date -r "$epoch" "$format" >/dev/null 2>&1; then
    value=$(date -r "$epoch" "$format")
  else
    value=$(date -d "@$epoch" "$format" 2>/dev/null || true)
  fi

  if [[ "$mode" == "time" ]]; then
    value=$(printf "%s" "$value" | sed -E 's/^0//; s/AM$/am/; s/PM$/pm/')
  fi

  printf "%s" "$value"
}

format_remaining() {
  local seconds="${1:-}"
  [[ -z "$seconds" ]] && echo "unknown" && return 0

  if ((seconds <= 0)); then
    echo "now"
    return 0
  fi

  local days=$((seconds / 86400))
  local hours=$(((seconds % 86400) / 3600))
  local minutes=$(((seconds % 3600) / 60))

  if ((days > 0)); then
    printf "%dd %dh" "$days" "$hours"
  elif ((hours > 0)); then
    printf "%dh %dm" "$hours" "$minutes"
  else
    printf "%dm" "$minutes"
  fi
}

draw_reset() {
  local epoch="${1:-}" mode="${2:-datetime}"
  local reset_text="--"

  if [[ -n "$epoch" ]]; then
    local formatted now rel
    formatted=$(format_epoch_local "$epoch" "$mode")
    if [[ -n "$formatted" ]]; then
      now=$(date +%s)
      rel=$(format_remaining $((epoch - now)))
      reset_text="$formatted ($rel)"
    fi
  fi

  printf "  %-8s ${DIM}reset: %s${RESET}\n" "" "$reset_text"
}

SPINNER_FRAMES=('|' '/' '-' '\')
CURSOR_HIDDEN=0

spinner_frame() {
  local frame="${1:-0}"
  local idx=$((frame % ${#SPINNER_FRAMES[@]}))
  printf "%s" "${SPINNER_FRAMES[$idx]}"
}

hide_cursor() {
  if [[ -t 1 && $CURSOR_HIDDEN -eq 0 ]]; then
    printf "\033[?25l"
    CURSOR_HIDDEN=1
  fi
}

show_cursor() {
  if [[ -t 1 && $CURSOR_HIDDEN -eq 1 ]]; then
    printf "\033[?25h"
    CURSOR_HIDDEN=0
  fi
}

move_to_render_start() {
  local lines="${1:-0}"
  ((lines <= 0)) && return 0

  printf "\033[%dF" "$lines"
}

render_line() {
  printf "\033[2K%s\n" "$1"
}

render_heading_line() {
  printf "\033[2K%b%s%b\n" "$BOLD" "$1" "$RESET"
}

render_spinner_line() {
  printf "\033[2K%b%s%b %b%s%b\n" "$BOLD" "$1" "$RESET" "$DIM" "$2" "$RESET"
}

clear_extra_render_lines() {
  local lines="${1:-0}" i
  ((lines <= 0)) && return 0

  for ((i = 0; i < lines; i++)); do
    printf "\033[2K\n"
  done
}

SECTION_LINES=0
render_provider_section() {
  local label="$1" tmp_file="$2" done="$3" frame="$4"
  local lines=0

  if ((done)); then
    render_heading_line "$label"
    lines=1
    while IFS= read -r line || [[ -n "$line" ]]; do
      render_line "$line"
      ((lines++))
    done <"$tmp_file"
  else
    local spin
    spin=$(spinner_frame "$frame")
    render_spinner_line "$label" "$spin"
    lines=1
  fi

  SECTION_LINES="$lines"
}

RENDERED_LINES=0
render_fetch_state() {
  local frame="$1"
  local label1="$2" tmp1="$3" done1="$4"
  local label2="$5" tmp2="$6" done2="$7" has_second="$8"
  local label3="${9:-}" tmp3="${10:-}" done3="${11:-0}" has_third="${12:-0}"
  local label4="${13:-}" tmp4="${14:-}" done4="${15:-0}" has_fourth="${16:-0}"
  local lines=0

  render_provider_section "$label1" "$tmp1" "$done1" "$frame"
  lines=$((lines + SECTION_LINES))

  if ((has_second)); then
    render_line ""
    ((lines++))
    render_provider_section "$label2" "$tmp2" "$done2" "$frame"
    lines=$((lines + SECTION_LINES))
  fi

  if ((has_third)); then
    render_line ""
    ((lines++))
    render_provider_section "$label3" "$tmp3" "$done3" "$frame"
    lines=$((lines + SECTION_LINES))
  fi

  if ((has_fourth)); then
    render_line ""
    ((lines++))
    render_provider_section "$label4" "$tmp4" "$done4" "$frame"
    lines=$((lines + SECTION_LINES))
  fi

  RENDERED_LINES="$lines"
}

wait_and_render_fetches() {
  local label1="$1" pid1="$2" tmp1="$3"
  local label2="${4:-}" pid2="${5:-}" tmp2="${6:-}"
  local label3="${7:-}" pid3="${8:-}" tmp3="${9:-}"
  local label4="${10:-}" pid4="${11:-}" tmp4="${12:-}"
  local has_second=0 has_third=0 has_fourth=0 frame=0 prev_lines=0
  local done1 done2 done3 done4

  [[ -n "$pid2" ]] && has_second=1
  [[ -n "$pid3" ]] && has_third=1
  [[ -n "$pid4" ]] && has_fourth=1

  hide_cursor
  while true; do
    done1=0
    done2=0
    done3=0
    done4=0

    kill -0 "$pid1" 2>/dev/null || done1=1
    if ((has_second)); then
      kill -0 "$pid2" 2>/dev/null || done2=1
    fi
    if ((has_third)); then
      kill -0 "$pid3" 2>/dev/null || done3=1
    fi
    if ((has_fourth)); then
      kill -0 "$pid4" 2>/dev/null || done4=1
    fi

    if [[ -t 1 ]]; then
      move_to_render_start "$prev_lines"
      render_fetch_state "$frame" "$label1" "$tmp1" "$done1" "$label2" "$tmp2" "$done2" "$has_second" "$label3" "$tmp3" "$done3" "$has_third" "$label4" "$tmp4" "$done4" "$has_fourth"
      clear_extra_render_lines $((prev_lines - RENDERED_LINES))
      if ((RENDERED_LINES > prev_lines)); then
        prev_lines="$RENDERED_LINES"
      fi
    fi

    if ((done1)) && ((!has_second || done2)) && ((!has_third || done3)) && ((!has_fourth || done4)); then
      break
    fi

    sleep 0.08
    frame=$((frame + 1))
  done

  wait "$pid1" || true
  ((has_second)) && { wait "$pid2" || true; }
  ((has_third)) && { wait "$pid3" || true; }
  ((has_fourth)) && { wait "$pid4" || true; }

  if [[ ! -t 1 ]]; then
    render_fetch_state "$frame" "$label1" "$tmp1" 1 "$label2" "$tmp2" "$has_second" "$has_second" "$label3" "$tmp3" "$has_third" "$has_third" "$label4" "$tmp4" "$has_fourth" "$has_fourth"
  fi

  show_cursor
}

run_provider_with_loading() {
  local label="$1" fetch_fn="$2"
  local tmp pid
  tmp=$(mktemp)

  "$fetch_fn" >"$tmp" &
  pid=$!

  cleanup() {
    show_cursor
    rm -f "$tmp"
    kill "$pid" 2>/dev/null
  }
  trap 'cleanup; trap - INT;  kill -INT  $$' INT
  trap 'cleanup; trap - TERM; kill -TERM $$' TERM
  trap 'cleanup' EXIT

  wait_and_render_fetches "$label" "$pid" "$tmp"
  rm -f "$tmp"
  trap - EXIT INT TERM
}

run_all_parallel() {
  local has_claude=0 has_codex=0 has_gemini=0 has_jetbrains=0
  if provider_available claude; then has_claude=1; fi
  if provider_available codex; then has_codex=1; fi
  if provider_available gemini; then has_gemini=1; fi
  if provider_available jetbrains; then has_jetbrains=1; fi

  local total=$((has_claude + has_codex + has_gemini + has_jetbrains))
  if ((total == 0)); then
    printf "No AI providers found (claude, codex, gemini, jetbrains).\n" >&2
    return 1
  fi
  if ((has_claude && total == 1)); then run_provider_with_loading "Claude" fetch_claude; return; fi
  if ((has_codex && total == 1)); then run_provider_with_loading "Codex" fetch_codex; return; fi
  if ((has_gemini && total == 1)); then run_provider_with_loading "Gemini" fetch_gemini; return; fi
  if ((has_jetbrains && total == 1)); then run_provider_with_loading "JetBrains" fetch_jetbrains; return; fi

  local claude_tmp="" codex_tmp="" gemini_tmp="" jetbrains_tmp=""
  local claude_pid="" codex_pid="" gemini_pid="" jetbrains_pid=""

  if ((has_claude)); then
    claude_tmp=$(mktemp)
    fetch_claude >"$claude_tmp" &
    claude_pid=$!
  fi
  if ((has_codex)); then
    codex_tmp=$(mktemp)
    fetch_codex >"$codex_tmp" &
    codex_pid=$!
  fi
  if ((has_gemini)); then
    gemini_tmp=$(mktemp)
    fetch_gemini >"$gemini_tmp" &
    gemini_pid=$!
  fi
  if ((has_jetbrains)); then
    jetbrains_tmp=$(mktemp)
    fetch_jetbrains >"$jetbrains_tmp" &
    jetbrains_pid=$!
  fi

  cleanup() {
    show_cursor
    [[ -n "$claude_tmp" ]] && rm -f "$claude_tmp"
    [[ -n "$codex_tmp" ]] && rm -f "$codex_tmp"
    [[ -n "$gemini_tmp" ]] && rm -f "$gemini_tmp"
    [[ -n "$jetbrains_tmp" ]] && rm -f "$jetbrains_tmp"
    [[ -n "$claude_pid" ]] && kill "$claude_pid" 2>/dev/null || true
    [[ -n "$codex_pid" ]] && kill "$codex_pid" 2>/dev/null || true
    [[ -n "$gemini_pid" ]] && kill "$gemini_pid" 2>/dev/null || true
    [[ -n "$jetbrains_pid" ]] && kill "$jetbrains_pid" 2>/dev/null || true
  }
  trap 'cleanup; trap - INT;  kill -INT  $$' INT
  trap 'cleanup; trap - TERM; kill -TERM $$' TERM
  trap 'cleanup' EXIT

  local labels=() pids=() tmps=()
  if ((has_claude)); then
    labels+=("Claude")
    pids+=("$claude_pid")
    tmps+=("$claude_tmp")
  fi
  if ((has_codex)); then
    labels+=("Codex")
    pids+=("$codex_pid")
    tmps+=("$codex_tmp")
  fi
  if ((has_gemini)); then
    labels+=("Gemini")
    pids+=("$gemini_pid")
    tmps+=("$gemini_tmp")
  fi
  if ((has_jetbrains)); then
    labels+=("JetBrains")
    pids+=("$jetbrains_pid")
    tmps+=("$jetbrains_tmp")
  fi

  wait_and_render_fetches \
    "${labels[0]}" "${pids[0]}" "${tmps[0]}" \
    "${labels[1]:-}" "${pids[1]:-}" "${tmps[1]:-}" \
    "${labels[2]:-}" "${pids[2]:-}" "${tmps[2]:-}" \
    "${labels[3]:-}" "${pids[3]:-}" "${tmps[3]:-}"
  [[ -n "$claude_tmp" ]] && rm -f "$claude_tmp"
  [[ -n "$codex_tmp" ]] && rm -f "$codex_tmp"
  [[ -n "$gemini_tmp" ]] && rm -f "$gemini_tmp"
  [[ -n "$jetbrains_tmp" ]] && rm -f "$jetbrains_tmp"
  trap - EXIT INT TERM
}

# ── claude ──────────────────────────────────────────────

fetch_claude() {
  local creds_file="$HOME/.claude/.credentials.json"
  local token=""

  if [[ -f "$creds_file" ]]; then
    token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds_file" 2>/dev/null)
  fi

  if [[ -z "$token" ]]; then
    # try macOS keychain
    token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null || true)
  fi

  if [[ -z "$token" ]]; then
    draw_error "not logged in run: claude /login"
    return
  fi

  local _sf resp _status
  _sf=$(mktemp)
  resp=$(HTTP_STATUS_FILE="$_sf" http_json \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    -H "Accept: application/json" \
    "https://api.anthropic.com/api/oauth/usage")
  _status=$(cat "$_sf" 2>/dev/null || echo "000")
  rm -f "$_sf"

  if [[ "$_status" != 2* ]] || [[ -z "$resp" ]]; then
    case "$_status" in
    401 | 403) draw_error "session expired run: claude /login" ;;
    000) draw_error "network error or request timed out" ;;
    *) draw_error "request failed (HTTP $_status)" ;;
    esac
    return
  fi

  local five_hour seven_day five_hour_reset seven_day_reset
  IFS=$'\t' read -r five_hour seven_day five_hour_reset seven_day_reset < <(
    printf '%s' "$resp" | jq -r 'def first_reset(w): w.reset_at // w.resets_at // w.resetAt // w.resetsAt // w.window_end // w.window_end_at // w.windowEnd // w.windowEndAt;
      [(.five_hour.utilization // ""),
       (.seven_day.utilization // ""),
       (first_reset(.five_hour) // ""),
       (first_reset(.seven_day) // "")] | @tsv' 2>/dev/null
  )

  local five_hour_reset_epoch seven_day_reset_epoch
  five_hour_reset_epoch=$(normalize_epoch "$five_hour_reset")
  seven_day_reset_epoch=$(normalize_epoch "$seven_day_reset")

  if [[ -n "$five_hour" ]]; then
    draw_bar "5h" "${five_hour%.*}"
  else
    draw_unavailable "5h"
  fi
  draw_reset "$five_hour_reset_epoch" "time"

  if [[ -n "$seven_day" ]]; then
    draw_bar "Weekly" "${seven_day%.*}"
  else
    draw_unavailable "Weekly"
  fi
  draw_reset "$seven_day_reset_epoch"

  local extra_enabled extra_util extra_used extra_limit
  IFS=$'\t' read -r extra_enabled extra_util extra_used extra_limit < <(
    printf '%s' "$resp" | jq -r '[(.extra_usage.is_enabled // false | tostring),
       (.extra_usage.utilization // ""),
       (.extra_usage.used_credits // ""),
       (.extra_usage.monthly_limit // "")] | @tsv' 2>/dev/null
  )

  if [[ "$extra_enabled" == "true" && -n "$extra_limit" && "$extra_limit" != "0" && "$extra_limit" != "null" ]]; then
    printf "\n"
    if [[ -n "$extra_util" ]]; then
      draw_bar "Extra" "${extra_util%.*}"
    else
      draw_unavailable "Extra"
    fi
    draw_credits_line "${extra_used:-0}" "$extra_limit"
  fi
}

# ── codex ───────────────────────────────────────────────

fetch_codex() {
  local creds_file="${CODEX_HOME:-$HOME/.codex}/auth.json"
  local token="" account_id=""

  if [[ -f "$creds_file" ]]; then
    token=$(jq -r '.tokens.access_token // empty' "$creds_file" 2>/dev/null)
    account_id=$(jq -r '.tokens.account_id // empty' "$creds_file" 2>/dev/null)
  fi

  if [[ -z "$token" ]]; then
    draw_error "not logged in run: codex login"
    return
  fi

  local headers=(-H "Authorization: Bearer $token" -H "Accept: application/json")
  [[ -n "$account_id" ]] && headers+=(-H "ChatGPT-Account-Id: $account_id")

  local _sf resp _status
  _sf=$(mktemp)
  resp=$(HTTP_STATUS_FILE="$_sf" http_json "${headers[@]}" "https://chatgpt.com/backend-api/wham/usage")
  _status=$(cat "$_sf" 2>/dev/null || echo "000")
  rm -f "$_sf"

  if [[ "$_status" != 2* ]] || [[ -z "$resp" ]]; then
    case "$_status" in
    401 | 403) draw_error "session expired log in to Codex again" ;;
    000) draw_error "network error or request timed out" ;;
    *) draw_error "request failed (HTTP $_status)" ;;
    esac
    return
  fi

  local primary secondary primary_reset secondary_reset
  IFS=$'\t' read -r primary secondary primary_reset secondary_reset < <(
    printf '%s' "$resp" | jq -r 'def first_reset(w): w.reset_at // w.resets_at // w.resetAt // w.resetsAt // w.window_end // w.window_end_at // w.windowEnd // w.windowEndAt;
      [(.rate_limit.primary_window.used_percent // ""),
       (.rate_limit.secondary_window.used_percent // ""),
       (first_reset(.rate_limit.primary_window) // ""),
       (first_reset(.rate_limit.secondary_window) // "")] | @tsv' 2>/dev/null
  )

  local primary_reset_epoch secondary_reset_epoch
  primary_reset_epoch=$(normalize_epoch "$primary_reset")
  secondary_reset_epoch=$(normalize_epoch "$secondary_reset")

  if [[ -n "$primary" ]]; then
    draw_bar "5h" "$primary"
  else
    draw_unavailable "5h"
  fi
  draw_reset "$primary_reset_epoch" "time"

  if [[ -n "$secondary" ]]; then
    draw_bar "Weekly" "$secondary"
  else
    draw_unavailable "Weekly"
  fi
  draw_reset "$secondary_reset_epoch"
}

# ── gemini ──────────────────────────────────────────────

gemini_account_email() {
  local accounts_file="${HOME}/.gemini/google_accounts.json"
  [[ -f "$accounts_file" ]] || return 0
  jq -r '.active // empty' "$accounts_file" 2>/dev/null || true
}

gemini_bucket_info() {
  case "$1" in
  gemini-2.5-flash)       printf '10\tFlash'  ;;
  gemini-2.5-pro)         printf '20\tPro'    ;;
  gemini-3-flash-preview) printf '30\tPreview' ;;
  gemini-3-pro-preview)   printf '30\tPreview' ;;
  gemini-2.5-flash-lite)  printf '50\tLite'   ;;
  *)                      printf '99\t%s' "$1" ;;
  esac
}

fetch_gemini() {
  local creds_file="$HOME/.gemini/oauth_creds.json"
  local access_token="" expiry_date=""

  if [[ -f "$creds_file" ]]; then
    local _creds
    _creds=$(jq -r '[.access_token // "", .expiry_date // ""] | @tsv' "$creds_file" 2>/dev/null)
    IFS=$'\t' read -r access_token expiry_date <<<"$_creds"
  fi

  if [[ -z "$access_token" ]]; then
    draw_error "not logged in run: gemini"
    return
  fi

  local now
  now=$(date +%s)
  if [[ -n "$expiry_date" && "$expiry_date" =~ ^[0-9]+$ ]]; then
    if ((expiry_date / 1000 <= now + 60)); then
      draw_error "session expired run: gemini"
      return
    fi
  fi

  local metadata project_hint load_resp project_id quota_resp
  local _sf load_status quota_status
  metadata='{"ideType":"IDE_UNSPECIFIED","platform":"PLATFORM_UNSPECIFIED","pluginType":"GEMINI"}'
  project_hint="${GOOGLE_CLOUD_PROJECT:-${GOOGLE_CLOUD_PROJECT_ID:-}}"

  _sf=$(mktemp)
  if [[ -n "$project_hint" ]]; then
    load_resp=$(HTTP_STATUS_FILE="$_sf" http_json \
      -H "Authorization: Bearer $access_token" \
      -H "Content-Type: application/json" \
      -d "{\"cloudaicompanionProject\":\"$project_hint\",\"metadata\":$metadata}" \
      "https://cloudcode-pa.googleapis.com/v1internal:loadCodeAssist")
  else
    load_resp=$(HTTP_STATUS_FILE="$_sf" http_json \
      -H "Authorization: Bearer $access_token" \
      -H "Content-Type: application/json" \
      -d "{\"metadata\":$metadata}" \
      "https://cloudcode-pa.googleapis.com/v1internal:loadCodeAssist")
  fi
  load_status=$(cat "$_sf" 2>/dev/null || echo "000")
  rm -f "$_sf"

  if [[ "$load_status" != 2* ]] || [[ -z "$load_resp" ]]; then
    case "$load_status" in
    401 | 403) draw_error "session expired run: gemini" ;;
    000) draw_error "network error or request timed out" ;;
    *) draw_error "request failed (HTTP $load_status)" ;;
    esac
    return
  fi

  project_id=$(printf '%s' "$load_resp" | jq -r '.cloudaicompanionProject // empty' 2>/dev/null)
  [[ -z "$project_id" && -n "$project_hint" ]] && project_id="$project_hint"

  if [[ -z "$project_id" ]]; then
    local validation_url
    validation_url=$(printf '%s' "$load_resp" | jq -r '.ineligibleTiers[]?.validationUrl // empty' 2>/dev/null | head -n1)
    if [[ -n "$validation_url" ]]; then
      draw_error "validation required see: $validation_url"
    else
      draw_error "Gemini project/quota is unavailable"
    fi
    return
  fi

  _sf=$(mktemp)
  quota_resp=$(HTTP_STATUS_FILE="$_sf" http_json \
    -H "Authorization: Bearer $access_token" \
    -H "Content-Type: application/json" \
    -d "{\"project\":\"$project_id\"}" \
    "https://cloudcode-pa.googleapis.com/v1internal:retrieveUserQuota")
  quota_status=$(cat "$_sf" 2>/dev/null || echo "000")
  rm -f "$_sf"

  if [[ "$quota_status" != 2* ]] || [[ -z "$quota_resp" ]]; then
    case "$quota_status" in
    401 | 403) draw_error "session expired run: gemini" ;;
    000) draw_error "network error or request timed out" ;;
    *) draw_error "request failed (HTTP $quota_status)" ;;
    esac
    return
  fi

  local bucket_rows=()
  while IFS=$'\t' read -r model_id percent reset_time; do
    [[ -z "$model_id" ]] && continue
    local _info _order _label
    IFS=$'\t' read -r _order _label <<<"$(gemini_bucket_info "$model_id")"
    bucket_rows+=("$_order"$'\t'"$_label"$'\t'"$percent"$'\t'"$reset_time")
  done < <(
    printf '%s' "$quota_resp" | jq -r '.buckets[]? | [.modelId // "", (((1 - (.remainingFraction // 1)) * 100) | round | tostring), .resetTime // ""] | @tsv' 2>/dev/null
  )

  if (( ${#bucket_rows[@]} == 0 )); then
    draw_error "Gemini quota data is unavailable"
    return
  fi

  local summary_percent=-1 summary_reset_epoch="" detail_line=""
  local grouped_rows
  grouped_rows=$(printf '%s\n' "${bucket_rows[@]}" | sort -t $'\t' -k1,1n | awk -F '\t' '
    {
      label=$2
      percent=$3 + 0
      reset=$4
      if (!(label in max) || percent > max[label]) {
        max[label]=percent
      }
      if (!(label in latest) || reset > latest[label]) {
        latest[label]=reset
      }
      if (!(label in ord)) {
        ord[label]=$1 + 0
        labels[++count]=label
      }
    }
    END {
      for (i=1; i<=count; i++) {
        label=labels[i]
        printf "%d\t%s\t%d\t%s\n", ord[label], label, max[label], latest[label]
      }
    }')

  local order label percent reset_time reset_epoch
  while IFS=$'\t' read -r order label percent reset_time; do
    [[ -n "$order" ]] || continue

    if (( summary_percent < 0 || percent > summary_percent )); then
      summary_percent=$percent
    fi

    reset_epoch=$(normalize_epoch "$reset_time")
    if [[ -n "$reset_epoch" ]] && (( reset_epoch > ${summary_reset_epoch:-0} )); then
      summary_reset_epoch="$reset_epoch"
    fi

    if [[ -n "$detail_line" ]]; then
      detail_line+="  "
    fi
    detail_line+="$label ${percent}%"
  done <<<"$grouped_rows"

  if (( summary_percent >= 0 )); then
    draw_bar "Daily" "$summary_percent"
  else
    draw_unavailable "Daily"
  fi
  draw_reset "$summary_reset_epoch"

  if [[ -n "$detail_line" ]]; then
    printf "  %-8s ${DIM}detail: %s${RESET}\n" "" "$detail_line"
  fi

}

# ── jetbrains ───────────────────────────────────────────

fetch_jetbrains() {
  local quota_file quota_info next_refill
  quota_file=$(find_jetbrains_quota_file)

  # JetBrains reads from a local file and can complete before the spinner paints.
  # Keep a brief delay so its loading state is visible like the network-backed providers.
  sleep 0.25

  if [[ -z "$quota_file" || ! -f "$quota_file" ]]; then
    draw_error "no JetBrains AI quota file found"
    return
  fi

  local raw_quota_info raw_next_refill quota_row
  quota_row=$(
    awk '
      /name="quotaInfo"/ && match($0, /value="[^"]*"/) {
        qi = substr($0, RSTART + 7, RLENGTH - 8)
      }
      /name="nextRefill"/ && match($0, /value="[^"]*"/) {
        nr = substr($0, RSTART + 7, RLENGTH - 8)
      }
      END { printf "%s\t%s\n", qi, nr }
    ' "$quota_file"
  )
  IFS=$'\t' read -r raw_quota_info raw_next_refill <<<"$quota_row"
  quota_info=$(xml_unescape "$raw_quota_info")
  next_refill=$(xml_unescape "$raw_next_refill")

  if [[ -z "$quota_info" ]]; then
    draw_error "JetBrains quota info is unavailable"
    return
  fi

  local quota_type current maximum until tariff_current tariff_max topup_current topup_max duration quota_values
  quota_values=$(
    {
      printf '%s' "$quota_info" | jq -r '[
        (.type // ""),
        (.current // ""),
        (.maximum // ""),
        (.until // ""),
        (.tariffQuota.current // ""),
        (.tariffQuota.maximum // ""),
        (.topUpQuota.current // ""),
        (.topUpQuota.maximum // "")
      ] | @tsv' 2>/dev/null
      printf '\t'
      printf '%s' "$next_refill" | jq -r '.tariff.duration // ""' 2>/dev/null
      printf '\n'
    }
  )
  IFS=$'\t' read -r quota_type current maximum until tariff_current tariff_max topup_current topup_max duration <<<"$quota_values"

  if [[ -z "$maximum" || "$maximum" == "0" || "$maximum" == "null" ]]; then
    draw_error "JetBrains quota limit is unavailable"
    return
  fi

  local percent reset_epoch label
  percent=$(awk "BEGIN{printf \"%.0f\", ($current / $maximum) * 100}" 2>/dev/null || true)
  reset_epoch=$(normalize_epoch "$until")
  label=$(duration_to_label "$duration")

  if [[ -n "$percent" ]]; then
    draw_bar "$label" "$percent"
  else
    draw_unavailable "$label"
  fi
  draw_reset "$reset_epoch"

  printf "  %-8s ${DIM}%s / %s credits${RESET}\n" "" "${current%.*}" "${maximum%.*}"

  if [[ -n "$topup_max" && "$topup_max" != "0" && "$topup_max" != "null" ]]; then
    local topup_percent
    topup_percent=$(awk "BEGIN{printf \"%.0f\", ($topup_current / $topup_max) * 100}" 2>/dev/null || true)
    printf "\n"
    if [[ -n "$topup_percent" ]]; then
      draw_bar "Top-up" "$topup_percent"
    else
      draw_unavailable "Top-up"
    fi
    printf "  %-8s ${DIM}%s / %s credits${RESET}\n" "" "${topup_current%.*}" "${topup_max%.*}"
  fi
}

# ── main ────────────────────────────────────────────────

usage() {
  cat <<'EOF'
Usage: aiusage [provider]

Providers:
  claude   Show only Claude usage
  codex    Show only Codex usage
  gemini   Show only Gemini CLI usage
  jetbrains Show only JetBrains AI usage

Omit provider to print all detected providers.
EOF
}

provider="${1:-all}"

case "$provider" in
all)
  run_all_parallel
  ;;
claude)
  if ! provider_available claude; then
    printf "claude is not installed\n" >&2
    exit 1
  fi
  run_provider_with_loading "Claude" fetch_claude
  ;;
codex)
  if ! provider_available codex; then
    printf "codex is not installed\n" >&2
    exit 1
  fi
  run_provider_with_loading "Codex" fetch_codex
  ;;
gemini)
  if ! provider_available gemini; then
    printf "gemini is not installed\n" >&2
    exit 1
  fi
  run_provider_with_loading "Gemini" fetch_gemini
  ;;
jetbrains)
  if ! provider_available jetbrains; then
    printf "jetbrains usage data is unavailable\n" >&2
    exit 1
  fi
  run_provider_with_loading "JetBrains" fetch_jetbrains
  ;;
-h | --help | help)
  usage
  exit 0
  ;;
*)
  printf "Unknown provider: %s\n\n" "$provider" >&2
  usage >&2
  exit 1
  ;;
esac

printf "\n"
